---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'dimadimadima',
  description = 'Dima Perkis — VP Data & Analytics. Builder of odd things.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === 'dimadimadima' ? 'dimadimadima' : `${title} — dimadimadima`}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />

</head>
<body>
  <div class="noise" aria-hidden="true"></div>

  <nav class="sticky top-0 z-50 bg-bg/90 backdrop-blur-sm border-b border-border">
    <div class="max-w-5xl mx-auto px-6 h-12 flex items-center justify-between">
      <a href="/" class="font-serif text-lg text-ink hover:text-gold transition-colors">
        dima<span class="text-gold italic">·</span>dima<span class="text-gold italic">·</span>dima
      </a>
      <div class="flex gap-6 text-[0.7rem] uppercase tracking-widest text-muted">
        <a href="/feed" class="hover:text-ink transition-colors">Feed</a>
        <a href="/resume" class="hover:text-ink transition-colors">Work</a>
        <a href="https://github.com/WhatWouldDimaDo" target="_blank" rel="noopener" class="hover:text-ink transition-colors">GitHub</a>
      </div>
    </div>
  </nav>

  <main class="max-w-5xl mx-auto px-6 pb-24">
    <slot />
  </main>

  <footer class="border-t border-border">
    <div class="max-w-5xl mx-auto px-6 py-6 flex items-center gap-3 text-[0.7rem] text-muted">
      <span>Atlanta, GA</span>
      <span class="text-border-hi">·</span>
      <span>dimadimadima.com</span>
      <span class="text-border-hi">·</span>
      <a href="https://github.com/WhatWouldDimaDo" target="_blank" rel="noopener" class="hover:text-gold transition-colors">@WhatWouldDimaDo</a>
    </div>
  </footer>
</body>
</html>
