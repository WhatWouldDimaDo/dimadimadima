  <script>
    // ─── Theme cycling: dark → light → hacker → dark ───────────────────
    const btn  = document.getElementById('theme-toggle') as HTMLButtonElement;
    const icon = document.getElementById('theme-icon') as HTMLSpanElement;
    const THEMES = ['dark', 'light', 'hacker'] as const;
    const ICONS  = { dark: '☀', light: '☾', hacker: '▊' };
    const THEME_LABELS = { dark: 'dark', light: 'light', hacker: 'hacker' };

    function syncTheme() {
      const t = (document.documentElement.getAttribute('data-theme') || 'dark') as keyof typeof ICONS;
      icon.textContent = ICONS[t] || '☀';
      const idx = THEMES.indexOf(t as typeof THEMES[number]);
      const next = THEMES[(idx >= 0 ? idx + 1 : 0) % THEMES.length];
      btn.setAttribute('aria-label', `Switch to ${THEME_LABELS[next]} theme (currently ${THEME_LABELS[t] || 'dark'})`);
    }
    syncTheme();

    btn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      const idx  = THEMES.indexOf(current as typeof THEMES[number]);
      const next = THEMES[(idx + 1) % THEMES.length];
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      syncTheme();
    });

    // ─── Mobile nav menu toggle ──────────────────────────────────────────
    const navMenuToggle = document.getElementById('nav-menu-toggle') as HTMLButtonElement | null;
    const navMenu = document.getElementById('nav-menu') as HTMLDivElement | null;
    if (navMenuToggle && navMenu) {
      navMenuToggle.addEventListener('click', () => {
        const isOpen = navMenu.classList.toggle('nav-menu-open');
        navMenuToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        navMenuToggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && navMenu.classList.contains('nav-menu-open')) {
          navMenu.classList.remove('nav-menu-open');
          navMenuToggle.setAttribute('aria-expanded', 'false');
          navMenuToggle.setAttribute('aria-label', 'Open menu');
          navMenuToggle.focus();
        }
      });
    }

    // ─── Konami code → grocery mode ─────────────────────────────────────
    const KONAMI = [38,38,40,40,37,39,37,39,66,65];
    let seq: number[] = [];
    document.addEventListener('keydown', (e) => {
      seq.push(e.keyCode);
      if (seq.length > KONAMI.length) seq.shift();
      if (seq.join(',') === KONAMI.join(',')) {
        const overlay = document.getElementById('grocery-overlay')!;
        overlay.style.display = overlay.style.display === 'none' ? 'block' : 'none';
        seq = [];
      }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const overlay = document.getElementById('grocery-overlay');
        if (overlay) overlay.style.display = 'none';
      }
    });
  </script>

  <script is:inline>
    // ─── heroNav: sticky nav slides in past scroll threshold ───────────
    (function() {
      if (document.documentElement.getAttribute('data-heronav') !== 'true') return;
      var nav = document.getElementById('site-nav');
      if (!nav) return;
      function update() {
        if (window.scrollY > 250) {
          nav.style.transform = 'translateY(0)';
          nav.style.opacity = '1';
        } else {
          nav.style.transform = 'translateY(-100%)';
          nav.style.opacity = '0';
        }
      }
      window.addEventListener('scroll', update, { passive: true });
      update();
    })();
  </script>
</body>
</html>
