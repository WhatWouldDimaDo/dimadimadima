---
import Layout from '../layouts/Layout.astro';
import ResumeExperience from '../components/ResumeExperience';
---
<Layout title="Professional Experience">

  <!-- Header -->
  <section style="padding-top:4rem;padding-bottom:2.5rem;border-bottom:1px solid var(--border);">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:2rem;flex-wrap:wrap;">
      <div>
        <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2.5rem,8vw,5rem);line-height:1;letter-spacing:-.02em;color:var(--ink);margin:0 0 .75rem;">
          Dima Perkis
        </h1>
        <p style="font-size:.75rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin:0 0 .5rem;">
          VP, Data & AI · Atlanta, GA
        </p>
        <p style="font-size:.875rem;color:var(--muted);max-width:40rem;line-height:1.65;margin:0 0 .75rem;">
          I build AI strategies at the enterprise level and deploy the systems that make them
          real — from Board rooms to front-line teams.
        </p>
        <a href="https://linkedin.com/in/dima-perkis" target="_blank" rel="noopener noreferrer"
          style="font-size:.75rem;text-transform:uppercase;letter-spacing:.1em;color:var(--gold);text-decoration:none;">
          linkedin.com/in/dima-perkis ↗
        </a>
      </div>
      <img src="/images/dima.jpeg" alt="Dima Perkis"
        style="width:140px;height:140px;border-radius:50%;object-fit:cover;border:2px solid var(--border);flex-shrink:0;" />
    </div>
  </section>

  <!-- Highlight strip -->
  <section style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-top:2rem;margin-bottom:2.5rem;">
    {[
      { n: '15+',   label: 'Years experience' },
      { n: '7',     label: 'Companies' },
    ].map(s => (
        <div style="background:var(--surface);padding:1.25rem;text-align:center;">
          <div style="font-family:'DM Serif Display',serif;font-size:2rem;color:var(--gold);line-height:1;">{s.n}</div>
          <div style="font-size:.75rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-top:.25rem;">{s.label}</div>
        </div>
    ))}
  </section>

  <!-- Experience (React island with filtering) -->
  <section style="margin-bottom:3rem;">
    <h2 style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin-bottom:1rem;">Experience</h2>
    <ResumeExperience client:load />
  </section>

  <!-- Education -->
  <section style="margin-bottom:3rem;">
    <h2 style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin-bottom:1rem;">Education</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,300px),1fr));gap:1rem;">
      {[
        {
          logo: '/images/logos/fuqua.svg',
          degree: 'MBA',
          school: 'Duke University',
          program: 'Fuqua School of Business',
          year: '2017',
          notes: 'Focus: Strategy & Finance. Founded Fuqua Motorcycle Club. PwC M&A internship.',
          color: '#012169',
        },
        {
          logo: '/images/logos/emory.svg',
          degree: 'BBA',
          school: 'Emory University',
          program: 'Goizueta Business School',
          year: '2009',
          notes: "Concentrations: Marketing & Russian. Dean's List. Study abroad in Czech Republic.",
          color: '#002878',
        },
      ].map(e => (
        <div style="background:var(--surface);padding:1.5rem;display:flex;flex-direction:column;gap:.75rem;border:1px solid var(--border);">
          <div style="display:flex;align-items:center;gap:1rem;">
            <img src={e.logo} alt={e.school} style="height:32px;width:auto;max-width:100px;object-fit:contain;opacity:.85;" />
          </div>
          <div>
            <div style="font-family:'DM Serif Display',serif;font-size:1.1rem;color:var(--ink);">{e.degree} — {e.school}</div>
            <div style={`font-size:.75rem;color:${e.color};margin:.2rem 0;`}>{e.program}</div>
            <div style="font-size:.7rem;color:var(--muted);">{e.year}</div>
          </div>
          <p style="font-size:.775rem;color:var(--muted);line-height:1.55;margin:0;">{e.notes}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Skills & Tools -->
  <section style="margin-bottom:3rem;">
    <h2 style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin-bottom:1rem;">Skills</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,220px),1fr));gap:.75rem;margin-bottom:2rem;">
      {[
        { icon: '🧭', label: 'AI Strategy & Enablement' },
        { icon: '📊', label: 'Analytics Leadership' },
        { icon: '🤖', label: 'LLM Agent Workflows' },
        { icon: '📈', label: 'Go-to-Market & Pricing' },
        { icon: '🎤', label: 'Executive Communication' },
        { icon: '⚙️', label: 'Systems Building — Python · SQL · TypeScript' },
      ].map(s => (
        <div style="display:flex;align-items:center;gap:.75rem;background:var(--surface);border:1px solid var(--border);padding:.75rem 1rem;">
          <span style="font-size:1.15rem;flex-shrink:0;">{s.icon}</span>
          <span style="font-size:.8rem;color:var(--ink);line-height:1.4;">{s.label}</span>
        </div>
      ))}
    </div>

    <h2 style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin-bottom:1rem;">Tools I Work With</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,150px),1fr));gap:.75rem;">
      {[
        { logo: '/images/logos/tools/openai.svg',       label: 'GPT' },
        { logo: '/images/logos/tools/claude.svg',       label: 'Claude' },
        { logo: '/images/logos/tools/googlegemini.svg', label: 'Gemini' },
        { logo: '/images/logos/tools/github.svg',       label: 'GitHub' },
        { logo: '/images/logos/tools/vercel.svg',       label: 'Vercel' },
        { logo: '/images/logos/tools/replit.svg',       label: 'Replit' },
      ].map(t => (
        <div style="display:flex;align-items:center;gap:.75rem;background:var(--surface);border:1px solid var(--border);padding:.75rem 1rem;">
          <img src={t.logo} alt={t.label}
            style="height:22px;width:22px;object-fit:contain;filter:var(--logo-filter);opacity:.85;flex-shrink:0;" />
          <span style="font-size:.8rem;color:var(--ink);">{t.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Outside work -->
  <section style="border-top:1px solid var(--border);padding-top:2rem;">
    <h2 style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin-bottom:1rem;">Outside Work</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,260px),1fr));gap:1rem;">
      {[
        { icon: '⛰', text: 'Completed the 29029 Everesting challenge — climbed the vertical equivalent of Everest (29,029 ft) in 36 hours on a ski mountain, in laps, on no sleep.' },
        { icon: '♫', text: 'Regular at live music shows. Building a Suno AI discography of original songs for my kids Dean and Ruby before they\'re old enough to be embarrassed by it.' },
        { icon: '🎭', text: 'Performs improv comedy. Personal motto: make a stranger laugh every day.' },
        { icon: '⚙', text: 'Compulsive builder: Chrome extensions, ML pipelines, AI systems, interactive data visualizations — if it\'s automatable, it\'s getting automated.' },
      ].map(f => (
        <div style="background:var(--surface);padding:1.25rem;border:1px solid var(--border);">
          <div style="font-size:1.25rem;margin-bottom:.5rem;">{f.icon}</div>
          <p style="font-size:.8125rem;color:var(--muted);line-height:1.65;margin:0;">{f.text}</p>
        </div>
      ))}
    </div>
  </section>

</Layout>
