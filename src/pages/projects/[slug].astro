---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const d = project.data;
const date = d.date ? d.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) : null;

const STATUS_CONFIG: Record<string, { label: string; color: string }> = {
  live:       { label: 'Live',       color: '#5a9a6e' },
  active:     { label: 'Active',     color: '#d4a853' },
  built:      { label: 'Built',      color: '#7c6fcd' },
  concept:    { label: 'Concept',    color: '#6b6a72' },
  research:   { label: 'Research',   color: '#6b8fad' },
  experiment: { label: 'Experiment', color: '#c07050' },
};
const statusMeta = d.status ? STATUS_CONFIG[d.status] ?? { label: d.status, color: '#6b6a72' } : null;

// Tech stack icon mapping — tag → { name, simpleicons slug, color }
const TOOL_MAP: Record<string, { name: string; icon: string; color: string }> = {
  'python':           { name: 'Python',       icon: 'python',         color: '#3776AB' },
  'react':            { name: 'React',        icon: 'react',          color: '#61DAFB' },
  'typescript':       { name: 'TypeScript',   icon: 'typescript',     color: '#3178C6' },
  'javascript':       { name: 'JavaScript',   icon: 'javascript',     color: '#F7DF1E' },
  'anthropic':        { name: 'Claude',       icon: 'anthropic',      color: '#D4A853' },
  'ai':               { name: 'Claude',       icon: 'anthropic',      color: '#D4A853' },
  'claude':           { name: 'Claude',       icon: 'anthropic',      color: '#D4A853' },
  'openai':           { name: 'OpenAI',       icon: 'openai',         color: '#eeeeee' },
  'gemini':           { name: 'Gemini',       icon: 'googlegemini',   color: '#8E75B2' },
  'perplexity':       { name: 'Perplexity',   icon: 'perplexity',     color: '#20B8CD' },
  'elevenlabs':       { name: 'ElevenLabs',   icon: 'elevenlabs',     color: '#F5A623' },
  'chrome-extension': { name: 'Chrome',       icon: 'googlechrome',   color: '#4285F4' },
  'obsidian':         { name: 'Obsidian',     icon: 'obsidian',       color: '#7C3AED' },
  'nextjs':           { name: 'Next.js',      icon: 'nextdotjs',      color: '#eeeeee' },
  'vercel':           { name: 'Vercel',       icon: 'vercel',         color: '#eeeeee' },
  'swift':            { name: 'Swift',        icon: 'swift',          color: '#F05138' },
  'docker':           { name: 'Docker',       icon: 'docker',         color: '#2496ED' },
  'ffmpeg':           { name: 'FFmpeg',       icon: 'ffmpeg',         color: '#007808' },
  'suno':             { name: 'Suno',         icon: 'suno',           color: '#FF6B35' },
  'sqlite':           { name: 'SQLite',       icon: 'sqlite',         color: '#003B57' },
  'aws':              { name: 'AWS',          icon: 'amazonaws',      color: '#FF9900' },
  'linux':            { name: 'Linux',        icon: 'linux',          color: '#FCC624' },
  'astro':            { name: 'Astro',        icon: 'astro',          color: '#FF5D01' },
  'tailwind':         { name: 'Tailwind',     icon: 'tailwindcss',    color: '#06B6D4' },
  'bun':              { name: 'Bun',          icon: 'bun',            color: '#FBF0DF' },
  'litellm':          { name: 'LiteLLM',      icon: 'anthropic',      color: '#D4A853' },
  'multi-agent':      { name: 'Multi-Agent',  icon: 'anthropic',      color: '#D4A853' },
  'mcp':              { name: 'MCP',          icon: 'anthropic',      color: '#D4A853' },
  'd2':               { name: 'D2',           icon: 'diagramsdotnet', color: '#F08705' },
  'tmdb':             { name: 'TMDB',         icon: 'themoviedatabase', color: '#01D277' },
  'firecrawl':        { name: 'Firecrawl',    icon: 'firebase',       color: '#DD2C00' },
};

const SKIP_TAGS = new Set(['ai', 'kids', 'editorial', 'ml', 'cv', 'family', 'dean', 'pipeline',
  'data-pipeline', 'data-analysis', 'network-analysis', 'scraping', 'voice', 'visualization',
  'newsletter', 'fintech', 'comics', 'sticker', 'illustration', 'music', 'automation',
  'productivity', 'adhd', 'tools', 'semantic-search', 'orchestration', 'platform',
  'open-source', 'infrastructure', 'streaming', 'sql', 'paw-patrol', 'macos', 'exiftool',
  'cli', 'ai-art', 'chatgpt', 'face-recognition', 'olama']);

const toolStack = d.tags
  .filter(t => !SKIP_TAGS.has(t) && TOOL_MAP[t])
  .map(t => ({ tag: t, ...TOOL_MAP[t] }))
  // dedupe by icon
  .filter((v, i, a) => a.findIndex(x => x.icon === v.icon) === i);

// Next project navigation — by order field
const allListed = (await getCollection('projects')).filter(p => p.data.listed !== false);
const sorted = allListed.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const currentIdx = sorted.findIndex(p => p.slug === project.slug);
const nextProject = currentIdx >= 0 && currentIdx < sorted.length - 1 ? sorted[currentIdx + 1] : null;
const prevProject = currentIdx > 0 ? sorted[currentIdx - 1] : null;
---
<Layout title={d.title} description={d.description}>

  <!-- Breadcrumb -->
  <nav style="padding-top:2rem;padding-bottom:1.5rem;">
    <a href="/projects" style="font-size:.65rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);text-decoration:none;transition:color .15s;" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--muted)'">
      ← Projects
    </a>
  </nav>

  <!-- Header -->
  <section style="padding-bottom:2.5rem;border-bottom:1px solid var(--border);">
    {d.image && (
      <div style="margin-bottom:2rem;">
        <div style="width:100%;max-height:460px;overflow:hidden;border:1px solid var(--border);border-radius:2px;">
          <img id="gallery-main" src={d.image} alt={d.title} style="width:100%;height:100%;object-fit:cover;object-position:top;transition:opacity .2s;" />
        </div>
        {d.images && d.images.length > 0 && (
          <div style="display:flex;gap:.625rem;margin-top:.75rem;flex-wrap:wrap;">
            {[d.image, ...d.images].map((img, i) => (
              <button
                data-src={img}
                onclick="var m=document.getElementById('gallery-main');var s=this.dataset.src;m.style.opacity='0';setTimeout(function(){m.src=s;m.style.opacity='1';},120);document.querySelectorAll('.gthumb').forEach(function(b){b.style.outline='none';});this.style.outline='2px solid var(--gold)';"
                class="gthumb"
                style={`width:120px;height:84px;overflow:hidden;border:1px solid var(--border);padding:0;cursor:pointer;background:none;flex-shrink:0;border-radius:2px;transition:outline .1s;outline:${i === 0 ? '2px solid var(--gold)' : 'none'};`}
              >
                <img src={img} alt={`${d.title} screenshot ${i + 1}`} style="width:100%;height:100%;object-fit:cover;object-position:top;" loading="lazy" />
              </button>
            ))}
          </div>
        )}
      </div>
    )}

    <div style="display:flex;align-items:flex-start;gap:1rem;flex-wrap:wrap;margin-bottom:1rem;">
      <div style="display:flex;flex-wrap:wrap;gap:.35rem;flex:1;">
        {d.tags.map((t: string) => (
          <span style="font-size:.6rem;font-family:'DM Mono',monospace;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);border:1px solid var(--border);padding:.2em .6em;border-radius:2px;">{t}</span>
        ))}
      </div>
      <div style="display:flex;align-items:center;gap:.5rem;flex-shrink:0;">
        {date && <span style="font-size:.65rem;color:var(--muted);font-family:'DM Mono',monospace;">{date}</span>}
        {statusMeta && (
          <span style={`font-size:.6rem;font-family:'DM Mono',monospace;text-transform:uppercase;letter-spacing:.08em;padding:.2em .6em;border-radius:2px;border:1px solid ${statusMeta.color}55;color:${statusMeta.color};`}>{statusMeta.label}</span>
        )}
      </div>
    </div>

    <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2rem,7vw,4rem);line-height:1.1;letter-spacing:-.02em;color:var(--ink);margin:0 0 1rem;">{d.title}</h1>
    <p style="font-size:.9rem;color:var(--muted);max-width:44rem;line-height:1.7;margin:0 0 1.5rem;">{d.description}</p>

    {d.url && (
      <a href={d.url} target="_blank" rel="noopener"
        style="display:inline-flex;align-items:center;gap:.5rem;font-size:.7rem;font-family:'DM Mono',monospace;text-transform:uppercase;letter-spacing:.1em;color:var(--gold);text-decoration:none;border:1px solid var(--gold)33;padding:.5em 1em;border-radius:2px;transition:all .15s;"
        onmouseover="this.style.background='rgba(212,168,83,.08)'" onmouseout="this.style.background='transparent'">
        ↗ View Live
      </a>
    )}
  </section>

  <!-- Tech stack strip -->
  {toolStack.length > 0 && (
    <section style="padding:1.5rem 0;border-bottom:1px solid var(--border);">
      <p style="font-size:.6rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin:0 0 1rem;">Built with</p>
      <div style="display:flex;flex-wrap:wrap;gap:.75rem;align-items:center;">
        {toolStack.map(tool => (
          <div title={tool.name} style="display:flex;flex-direction:column;align-items:center;gap:.4rem;opacity:.85;transition:opacity .15s;cursor:default;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='.85'">
            <div style={`width:36px;height:36px;border:1px solid var(--border);border-radius:4px;background:var(--surface);display:flex;align-items:center;justify-content:center;padding:6px;`}>
              <img
                src={`https://cdn.simpleicons.org/${tool.icon}/${tool.color.replace('#','')}`}
                alt={tool.name}
                width="24"
                height="24"
                style="width:100%;height:100%;object-fit:contain;"
                loading="lazy"
              />
            </div>
            <span style="font-size:.55rem;font-family:'DM Mono',monospace;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);">{tool.name}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Case study body -->
  <article style="margin-top:2.5rem;max-width:44rem;">
    <div class="prose">
      <Content />
    </div>
  </article>

  <!-- Next project navigation -->
  <div style="margin-top:4rem;padding-top:2rem;border-top:1px solid var(--border);">
    {nextProject ? (
      <>
        <p style="font-size:.58rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin:0 0 1rem;font-family:'DM Mono',monospace;">Up next</p>
        <a href={`/projects/${nextProject.slug}`} class="next-card">
          {nextProject.data.image && (
            <img src={nextProject.data.image} alt={nextProject.data.title} />
          )}
          <div>
            <div class="next-card-title">{nextProject.data.title}</div>
            <div class="next-card-desc">{nextProject.data.description}</div>
          </div>
          <span class="next-card-arrow">→</span>
        </a>
      </>
    ) : (
      <a href="/projects" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);text-decoration:none;transition:color .15s;" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--muted)'">
        ← All Projects
      </a>
    )}
  </div>

</Layout>

<style>
  .prose { color: var(--muted); font-size: .875rem; line-height: 1.75; }
  .prose h2 { font-family: 'DM Serif Display', serif; font-size: 1.5rem; color: var(--ink); margin: 2.5rem 0 .75rem; font-weight: 400; }
  .prose h3 { font-family: 'DM Serif Display', serif; font-size: 1.1rem; color: var(--ink); margin: 1.75rem 0 .5rem; font-weight: 400; }
  .prose p { margin: 0 0 1rem; }
  .prose ul { padding-left: 1.25rem; margin: 0 0 1rem; display: flex; flex-direction: column; gap: .35rem; }
  .prose ol { padding-left: 1.25rem; margin: 0 0 1rem; display: flex; flex-direction: column; gap: .35rem; }
  .prose li { line-height: 1.65; }
  .prose strong { color: var(--ink); font-weight: 600; }
  .prose code { font-family: 'DM Mono', monospace; font-size: .8em; background: var(--border); padding: .15em .4em; border-radius: 2px; color: var(--gold); }
  .prose blockquote { border-left: 2px solid var(--gold); padding-left: 1rem; margin: 1.5rem 0; color: var(--ink); font-family: 'DM Serif Display', serif; font-size: 1.05rem; line-height: 1.6; }
  .prose a { color: var(--gold); text-decoration: none; }
  .prose a:hover { text-decoration: underline; }
  .prose hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
  .prose table { width: 100%; border-collapse: collapse; font-size: .8rem; margin: 1.5rem 0; }
  .prose th { text-align: left; padding: .5rem .75rem; border-bottom: 1px solid var(--border-hi); color: var(--ink); font-family: 'DM Mono', monospace; font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; font-weight: 500; }
  .prose td { padding: .5rem .75rem; border-bottom: 1px solid var(--border); color: var(--muted); }
  .prose tr:last-child td { border-bottom: none; }

  /* Pipeline flow styles (used inline in .md files) */
  .pipeline-flow {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    margin: 2rem 0;
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .pipeline-step {
    flex: 1;
    min-width: 120px;
    background: var(--surface);
    padding: 1.25rem 1rem;
    border-right: 1px solid var(--border);
    position: relative;
  }
  .pipeline-step:last-child { border-right: none; }
  .pipeline-step::after {
    content: '→';
    position: absolute;
    right: -0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--gold);
    font-size: 1rem;
    z-index: 1;
  }
  .pipeline-step:last-child::after { display: none; }
  .pipeline-num {
    font-size: .6rem;
    font-family: 'DM Mono', monospace;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: .1em;
    margin-bottom: .35rem;
  }
  .pipeline-label {
    font-family: 'DM Serif Display', serif;
    font-size: .95rem;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: .35rem;
  }
  .pipeline-desc {
    font-size: .7rem;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    line-height: 1.4;
  }

  /* Live embed toggle */
  .live-embed-wrap { margin: 2rem 0; }
  .live-embed-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: .75rem 1rem;
    border-radius: 2px;
  }
  .live-embed-header span { font-size: .7rem; color: var(--muted); font-family: 'DM Mono', monospace; }
  .live-embed-btn {
    font-size: .65rem; font-family: 'DM Mono', monospace;
    text-transform: uppercase; letter-spacing: .1em;
    color: var(--gold); background: transparent;
    border: 1px solid var(--gold)44; padding: .3em .8em;
    border-radius: 2px; cursor: pointer; transition: all .15s;
  }
  .live-embed-btn:hover { background: rgba(212,168,83,.08); }

  /* Stat callout block */
  .stat-callout {
    border: 1px solid var(--gold)44;
    background: rgba(212,168,83,.06);
    padding: 1.25rem 1.5rem;
    margin: 1.75rem 0;
    border-radius: 2px;
  }
  .stat-callout .stat-number {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem;
    color: var(--gold);
    line-height: 1;
    display: block;
    margin-bottom: .25rem;
  }
  .stat-callout .stat-label {
    font-size: .75rem;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  /* Next project card */
  .next-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: .75rem;
    border-radius: 2px;
    transition: border-color .2s, transform .2s;
  }
  .next-card:hover {
    border-color: var(--border-hi);
    transform: translateY(-1px);
  }
  .next-card img {
    width: 120px;
    height: 80px;
    object-fit: cover;
    object-position: top;
    border-radius: 2px;
    flex-shrink: 0;
  }
  .next-card-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.05rem;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: .25rem;
  }
  .next-card-desc {
    font-size: .7rem;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    line-height: 1.4;
  }
  .next-card-arrow {
    margin-left: auto;
    font-size: 1.5rem;
    color: var(--gold);
    opacity: .35;
    transition: opacity .15s, transform .15s;
    flex-shrink: 0;
    padding-right: .5rem;
  }
  .next-card:hover .next-card-arrow {
    opacity: 1;
    transform: translateX(4px);
  }
  @media (max-width: 480px) {
    .next-card img { width: 80px; height: 54px; }
    .next-card-desc { display: none; }
  }
</style>
