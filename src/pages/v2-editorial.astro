---
import LayoutEditorial from '../layouts/LayoutEditorial.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter(p => p.data.featured && p.data.order < 10)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const selected = allProjects
  .filter(p => p.data.order < 10 && p.data.listed !== false)
  .sort((a, b) => a.data.order - b.data.order);

const [feat1, feat2, feat3] = featured;
---

<LayoutEditorial title="Dima Perkis" description="VP Strategy & Analytics. I build things.">

  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title">Dima Perkis</h1>
      <p class="hero-subtitle">VP Strategy & Analytics. I build things.</p>
      <div class="hero-accent"></div>
    </div>
  </section>

  <section class="featured-grid">
    {feat1 && (
      <a href={`/projects/${feat1.slug}`} class="feat-card feat-card--large">
        {feat1.data.image && <img src={feat1.data.image} alt={feat1.data.title} loading="lazy" />}
        <div class="feat-card-overlay">
          <div class="feat-card-tag">{feat1.data.tags[0]}</div>
          <h2 class="feat-card-title">{feat1.data.title}</h2>
          <p class="feat-card-desc">{feat1.data.description}</p>
        </div>
      </a>
    )}
    <div class="feat-stack">
      {feat2 && (
        <a href={`/projects/${feat2.slug}`} class="feat-card feat-card--small">
          {feat2.data.image && <img src={feat2.data.image} alt={feat2.data.title} loading="lazy" />}
          <div class="feat-card-overlay">
            <div class="feat-card-tag">{feat2.data.tags[0]}</div>
            <h3 class="feat-card-title">{feat2.data.title}</h3>
            <p class="feat-card-desc">{feat2.data.description}</p>
          </div>
        </a>
      )}
      {feat3 && (
        <a href={`/projects/${feat3.slug}`} class="feat-card feat-card--small">
          {feat3.data.image && <img src={feat3.data.image} alt={feat3.data.title} loading="lazy" />}
          <div class="feat-card-overlay">
            <div class="feat-card-tag">{feat3.data.tags[0]}</div>
            <h3 class="feat-card-title">{feat3.data.title}</h3>
            <p class="feat-card-desc">{feat3.data.description}</p>
          </div>
        </a>
      )}
    </div>
  </section>

  <section class="stats">
    <div class="stat">
      <div class="stat-num">15+</div>
      <div class="stat-label">Years</div>
    </div>
    <div class="stat">
      <div class="stat-num">178</div>
      <div class="stat-label">Shows</div>
    </div>
    <div class="stat">
      <div class="stat-num">30+</div>
      <div class="stat-label">Projects</div>
    </div>
  </section>

  <section class="selected">
    <h2 class="selected-heading">Selected Work</h2>
    <ul class="selected-list">
      {selected.map(p => (
        <li class="selected-item" data-slug={p.slug}>
          <a href={`/projects/${p.slug}`} class="selected-link">
            <span class="selected-name">{p.data.title}</span>
            <span class="selected-tags">{p.data.tags.slice(0, 3).join(' · ')}</span>
            <span class="selected-arrow">→</span>
          </a>
          {p.data.image && <div class="selected-preview"><img src={p.data.image} alt="" loading="lazy" /></div>}
        </li>
      ))}
    </ul>
  </section>

  <section class="cta-band">
    <div class="cta-content">
      <h2 class="cta-title">Let's build something odd together.</h2>
      <a href="/about" class="cta-link">Get in touch →</a>
    </div>
  </section>

</LayoutEditorial>

<style>
  :global(.editorial-body) {
    background: var(--bg);
  }

  .hero {
    min-height: calc(100vh - 3rem);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--bg) 0%, color-mix(in srgb, var(--surface) 60%, var(--bg)) 100%);
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 120px;
    background: var(--gold);
    opacity: 0.5;
  }

  .hero-content {
    text-align: center;
    padding: 2rem;
  }

  .hero-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 0 0 1rem;
  }

  .hero-subtitle {
    font-family: 'DM Mono', monospace;
    font-size: 1.25rem;
    color: var(--muted);
    margin: 0;
  }

  .hero-accent {
    width: 60px;
    height: 2px;
    background: var(--gold);
    margin: 2rem auto 0;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1rem;
    padding: 4rem 0;
  }

  .feat-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: border-color 0.3s;
  }

  .feat-card:hover {
    border-color: var(--gold);
  }

  .feat-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .feat-card:hover img {
    transform: scale(1.08);
  }

  .feat-card--large {
    grid-column: 1 / 5;
    min-height: 500px;
  }

  .feat-stack {
    grid-column: 5 / 13;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .feat-card--small {
    flex: 1;
    min-height: 240px;
  }

  .feat-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(12,12,14,0.95) 40%, transparent 100%);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .feat-card-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .feat-card-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    color: #fff;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }

  .feat-card-desc {
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    color: rgba(232,230,224,0.6);
    line-height: 1.6;
    margin: 0;
    max-width: 40rem;
  }

  .stats {
    display: flex;
    justify-content: space-around;
    padding: 4rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .stat {
    text-align: center;
  }

  .stat-num {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 1;
    color: var(--gold);
  }

  .stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
    margin-top: 0.5rem;
  }

  .selected {
    padding: 4rem 0;
  }

  .selected-heading {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: var(--ink);
    margin: 0 0 2rem;
  }

  .selected-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .selected-item {
    position: relative;
    border-bottom: 1px solid var(--border);
  }

  .selected-link {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
  }

  .selected-item:hover .selected-link {
    color: var(--gold);
  }

  .selected-name {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    flex: 1;
  }

  .selected-tags {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    opacity: 0.7;
  }

  .selected-arrow {
    font-size: 1.25rem;
    opacity: 0;
    transform: translateX(-10px);
    transition: opacity 0.2s, transform 0.2s;
    color: var(--gold);
  }

  .selected-item:hover .selected-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .selected-preview {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 200px;
    height: 120px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
    overflow: hidden;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .selected-item:hover .selected-preview {
    opacity: 1;
  }

  .selected-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cta-band {
    background: var(--gold);
    color: #0c0c0e;
    padding: 4rem 2rem;
    margin: 2rem -1.5rem -6rem;
    text-align: center;
  }

  .cta-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0 0 1.5rem;
    color: #0c0c0e;
  }

  .cta-link {
    font-family: 'DM Mono', monospace;
    font-size: 1rem;
    color: #0c0c0e;
    text-decoration: none;
    border-bottom: 2px solid #0c0c0e;
    padding-bottom: 0.25rem;
    transition: opacity 0.2s;
  }

  .cta-link:hover {
    opacity: 0.7;
  }

  @media (max-width: 860px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }
    .feat-card--large {
      grid-column: 1;
      min-height: 300px;
    }
    .feat-stack {
      grid-column: 1;
    }
    .stats {
      flex-direction: column;
      gap: 2rem;
    }
    .selected-preview {
      display: none;
    }
  }
</style>
