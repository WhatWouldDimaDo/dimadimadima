---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
  defaultTheme?: string;
}
const {
  title = 'dimadimadima',
  description = 'Dima Perkis — VP Strategy & Analytics. Builder of odd things.',
  defaultTheme,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme={defaultTheme || 'dark'} data-dt={defaultTheme || ''}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === 'dimadimadima' ? 'dimadimadima' : (title === 'Dima Perkis' ? 'Dima Perkis — dimadimadima' : `${title} — Dima Perkis`)}</title>
  <!-- Open Graph -->
  <meta property="og:title" content={title === 'dimadimadima' ? 'dimadimadima — Dima Perkis' : `${title} — Dima Perkis`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://dimadimadima.com${Astro.url.pathname}`} />
  <meta property="og:image" content="https://dimadimadima.com/images/brand/dima-dima-dima/og-card.png" />
  <meta property="og:site_name" content="dimadimadima" />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title === 'dimadimadima' ? 'dimadimadima — Dima Perkis' : `${title} — dimadimadima`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://dimadimadima.com/images/brand/dima-dima-dima/og-card.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/images/brand/dima-dima-dima/png/dima-mark-concept-01-32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/images/brand/dima-dima-dima/png/dima-mark-concept-01-192.png" />
  <link rel="apple-touch-icon" href="/images/brand/dima-dima-dima/png/dima-mark-concept-01-touch-180.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <!-- Prevent theme flash -->
  <script is:inline>
    (function() {
      var el = document.documentElement;
      var dt = el.getAttribute('data-dt') || 'dark';
      var saved = localStorage.getItem('theme') || dt;
      el.setAttribute('data-theme', saved);
    })();
  </script>
  <!-- Vercel Web Analytics (requires Analytics enabled on the Vercel project) -->
  <script is:inline defer src="/_vercel/insights/script.js"></script>
</head>
<body>
  <div class="noise" aria-hidden="true"></div>

  <nav style="position:sticky;top:0;z-index:50;background-color:color-mix(in srgb,var(--bg) 92%,transparent);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);">
    <div style="max-width:64rem;margin:0 auto;padding:0 1.5rem;height:3rem;display:flex;align-items:center;justify-content:space-between;">
      <a href="/" class="site-brand" aria-label="dimadimadima home">
        <img src="/images/brand/dima-dima-dima/png/dima-mark-concept-01-192.png" alt="" aria-hidden="true"
          style="height:30px;width:auto;display:block;" />
        <img src="/images/brand/dima-dima-dima/dima-wordmark-concept-09-transparent.png" alt="dima dima dima"
          style="height:16px;width:auto;display:block;" />
      </a>
      <div class="site-nav-links" style="display:flex;align-items:center;gap:1.25rem;">
        <a class="site-nav-link" href="/resume" style={'font-size:0.8rem;text-transform:uppercase;letter-spacing:.1em;text-decoration:none;transition:color .2s;' + (Astro.url.pathname === '/resume' ? 'color:var(--ink);' : 'color:var(--muted);')} onmouseover="this.style.color='var(--ink)'" onmouseout={Astro.url.pathname === '/resume' ? "this.style.color='var(--ink)'" : "this.style.color='var(--muted)'"}><span class="nav-label-long">Professional Experience</span><span class="nav-label-short">Work</span></a>
        <a class="site-nav-link" href="/projects" style={'font-size:0.8rem;text-transform:uppercase;letter-spacing:.1em;text-decoration:none;transition:color .2s;' + (Astro.url.pathname.startsWith('/projects') ? 'color:var(--ink);' : 'color:var(--muted);')} onmouseover="this.style.color='var(--ink)'" onmouseout={Astro.url.pathname.startsWith('/projects') ? "this.style.color='var(--ink)'" : "this.style.color='var(--muted)'"}><span class="nav-label-long">AI Side Quests</span><span class="nav-label-short">Projects</span></a>
        <a class="site-nav-link" href="/about" style={'font-size:0.8rem;text-transform:uppercase;letter-spacing:.1em;text-decoration:none;transition:color .2s;' + (Astro.url.pathname === '/about' ? 'color:var(--ink);' : 'color:var(--muted);')} onmouseover="this.style.color='var(--ink)'" onmouseout={Astro.url.pathname === '/about' ? "this.style.color='var(--ink)'" : "this.style.color='var(--muted)'"}>About</a>
        <button id="theme-toggle" aria-label="Toggle theme" title="Cycle theme" style="background:none;border:1px solid var(--border);color:var(--muted);font-size:0.75rem;padding:.25em .6em;cursor:pointer;border-radius:3px;transition:all .2s;font-family:'DM Mono',monospace;">
          <span id="theme-icon">☀</span>
        </button>
      </div>
    </div>
  </nav>

  <main style="max-width:64rem;margin:0 auto;padding:0 1.5rem 6rem;">
    <slot />
  </main>

  <footer style="border-top:1px solid var(--border);">
    <div style="max-width:64rem;margin:0 auto;padding:1.5rem;display:flex;align-items:center;gap:.75rem;font-size:.8rem;color:var(--muted);">
      <span>Atlanta, GA</span>
      <span style="color:var(--border-hi);">·</span>
      <span>dimadimadima.com</span>
      <span style="color:var(--border-hi);">·</span>
      <a href="https://linkedin.com/in/dima-perkis" target="_blank" rel="noopener" style="color:var(--muted);text-decoration:none;transition:color .2s;" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--muted)'">linkedin.com/in/dima-perkis</a>
      <span style="margin-left:auto;opacity:.25;cursor:default;" title="↑↑↓↓←→←→BA">♫</span>
    </div>
  </footer>

  <!-- Grocery Mode Overlay -->
  <div id="grocery-overlay" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.88);backdrop-filter:blur(4px);overflow-y:auto;padding:2rem 1rem;cursor:pointer;" onclick="document.getElementById('grocery-overlay').style.display='none'">
    <div onclick="event.stopPropagation()" style="max-width:480px;margin:0 auto;background:#fefefe;color:#111;font-family:'Courier New',monospace;font-size:.8rem;line-height:1.6;padding:2rem 1.5rem;box-shadow:0 20px 60px rgba(0,0,0,.5);">
      <div style="text-align:center;border-bottom:2px dashed #ccc;padding-bottom:1rem;margin-bottom:1rem;">
        <div style="font-size:1.4rem;font-weight:bold;letter-spacing:.1em;">DIMADIMADIMA MART</div>
        <div style="font-size:.75rem;margin-top:.25rem;">"We Build Things. Sometimes."</div>
        <div style="font-size:.7rem;color:#555;margin-top:.15rem;">404 Mulberry Ln · Atlanta, GA · Est. 2009</div>
        <div style="font-size:.65rem;margin-top:.5rem;">CASHIER: Claude Sonnet &nbsp;&nbsp; REG: 04</div>
        <div style="font-size:.65rem;">MEMBER: Dima Perkis &nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span style="background:#111;color:#fefefe;padding:0 .3em;">GOLD</span></div>
      </div>

      <div style="margin-bottom:.75rem;">
        <div style="font-weight:bold;text-transform:uppercase;font-size:.7rem;border-bottom:1px solid #ccc;margin-bottom:.4rem;">AISLE 7 — ARTIFICIAL INTELLIGENCE</div>
        <div style="display:flex;justify-content:space-between;"><span>On Dima's Radar (fresh)</span><span>WEEKLY</span></div>
        <div style="display:flex;justify-content:space-between;"><span>LLM Router (store brand)</span><span>$0.99</span></div>
        <div style="display:flex;justify-content:space-between;"><span>Multi-Agent Cluster</span><span>$∞.00</span></div>
        <div style="display:flex;justify-content:space-between;"><span>&nbsp;&nbsp;<span style="color:#888;font-size:.7rem;">* BOGO on AI workflows this month</span></span><span></span></div>
      </div>

      <div style="margin-bottom:.75rem;">
        <div style="font-weight:bold;text-transform:uppercase;font-size:.7rem;border-bottom:1px solid #ccc;margin-bottom:.4rem;">AISLE 3 — DATA SCIENCE</div>
        <div style="display:flex;justify-content:space-between;"><span>Tarantino Graph</span><span>37 films</span></div>
        <div style="display:flex;justify-content:space-between;"><span>Concert History</span><span>2007–</span></div>
        <div style="display:flex;justify-content:space-between;"><span>Friend Relationship Sys</span><span>4,000+ ct</span></div>
      </div>

      <div style="margin-bottom:.75rem;">
        <div style="font-weight:bold;text-transform:uppercase;font-size:.7rem;border-bottom:1px solid #ccc;margin-bottom:.4rem;">AISLE 12 — FAMILY (ORGANIC)</div>
        <div style="display:flex;justify-content:space-between;"><span>ToddlerMaps Stickers</span><span>BULK</span></div>
        <div style="display:flex;justify-content:space-between;"><span>Adventure Bay (offline)</span><span>1 ea</span></div>
        <div style="display:flex;justify-content:space-between;"><span>Dean Comics</span><span>12 panels</span></div>
        <div style="display:flex;justify-content:space-between;"><span>Baby Ruby Lullabies</span><span>♫</span></div>
      </div>

      <div style="margin-bottom:.75rem;">
        <div style="font-weight:bold;text-transform:uppercase;font-size:.7rem;border-bottom:1px solid #ccc;margin-bottom:.4rem;">AISLE 9 — MUSIC</div>
        <div style="display:flex;justify-content:space-between;"><span>Suno Songs (bulk)</span><span>65 ea</span></div>
        <div style="display:flex;justify-content:space-between;"><span>Dad Squad Anthem</span><span>LIMITED</span></div>
      </div>

      <div style="margin-bottom:.75rem;">
        <div style="font-weight:bold;text-transform:uppercase;font-size:.7rem;border-bottom:1px solid #ccc;margin-bottom:.4rem;">AISLE 1 — CORPORATE (FANCY)</div>
        <div style="display:flex;justify-content:space-between;"><span>AI Strategy (premium)</span><span>PRICELESS</span></div>
        <div style="display:flex;justify-content:space-between;"><span>Analytics Leadership</span><span>15 YRS</span></div>
        <div style="display:flex;justify-content:space-between;"><span>Insights Guild</span><span>CROWN ✦</span></div>
      </div>

      <div style="border-top:2px dashed #ccc;padding-top:1rem;margin-top:.5rem;">
        <div style="display:flex;justify-content:space-between;"><span>SUBTOTAL</span><span>30+ PROJECTS</span></div>
        <div style="display:flex;justify-content:space-between;"><span>CHILDREN TAX (×2)</span><span>+CHAOS</span></div>
        <div style="display:flex;justify-content:space-between;"><span>ADHD SURCHARGE</span><span>ALWAYS</span></div>
        <div style="display:flex;justify-content:space-between;"><span>AGENTIC DISCOUNT</span><span>−6 HRS</span></div>
        <div style="display:flex;justify-content:space-between;font-weight:bold;font-size:1rem;margin-top:.5rem;border-top:1px solid #ccc;padding-top:.5rem;">
          <span>TOTAL</span><span>WORTH IT</span>
        </div>
      </div>

      <div style="border-top:2px dashed #ccc;padding-top:1rem;margin-top:1rem;text-align:center;">
        <div>PAYMENT: 15 YEARS EXPERIENCE</div>
        <div>CHANGE DUE: PERSPECTIVE</div>
        <div style="margin-top:.75rem;font-size:.7rem;color:#555;">YOU SAVED: 6 HRS (AGENTIC LABOR)</div>
        <div style="margin-top:1rem;font-weight:bold;">★ ★ ★ ★ ★</div>
        <div style="margin-top:.25rem;">Thank you for visiting!</div>
        <div style="font-size:.75rem;font-weight:bold;margin-top:.25rem;">dima·dima·dima MART</div>
        <div style="font-size:.65rem;color:#555;margin-top:.15rem;">"Come back when you have more data"</div>
        <div style="margin-top:1rem;font-size:.65rem;border-top:1px solid #eee;padding-top:.75rem;color:#888;">Press ESC or tap outside to exit</div>
      </div>
    </div>
  </div>

  <script>
    // ─── Theme cycling: dark → light → hacker → dark ───────────────────
    const btn  = document.getElementById('theme-toggle') as HTMLButtonElement;
    const icon = document.getElementById('theme-icon') as HTMLSpanElement;
    const THEMES = ['dark', 'light', 'hacker'] as const;
    const ICONS  = { dark: '☀', light: '☾', hacker: '▊' };

    function syncTheme() {
      const t = (document.documentElement.getAttribute('data-theme') || 'dark') as keyof typeof ICONS;
      icon.textContent = ICONS[t] || '☀';
    }
    syncTheme();

    btn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      const idx  = THEMES.indexOf(current as typeof THEMES[number]);
      const next = THEMES[(idx + 1) % THEMES.length];
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      syncTheme();
    });

    // ─── Konami code → grocery mode ─────────────────────────────────────
    const KONAMI = [38,38,40,40,37,39,37,39,66,65];
    let seq: number[] = [];
    document.addEventListener('keydown', (e) => {
      seq.push(e.keyCode);
      if (seq.length > KONAMI.length) seq.shift();
      if (seq.join(',') === KONAMI.join(',')) {
        const overlay = document.getElementById('grocery-overlay')!;
        overlay.style.display = overlay.style.display === 'none' ? 'block' : 'none';
        seq = [];
      }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const overlay = document.getElementById('grocery-overlay');
        if (overlay) overlay.style.display = 'none';
      }
    });
  </script>
</body>
</html>
