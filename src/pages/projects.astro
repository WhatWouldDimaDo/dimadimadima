---
import Layout from '../layouts/Layout.astro';
import ProjectsGrid from '../components/ProjectsGrid';
import { getCollection } from 'astro:content';

const all = (await getCollection('projects'))
  .filter(p => p.data.listed !== false)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const projects = all.map(p => ({
  slug:        p.slug,
  title:       p.data.title,
  description: p.data.description,
  tags:        p.data.tags,
  url:         p.data.url ?? undefined,
  image:       p.data.image ?? undefined,
  status:      p.data.status ?? undefined,
  date:        p.data.date ? p.data.date.toISOString() : undefined,
}));
---
<Layout title="Projects">
  <section style="padding-top:4rem;padding-bottom:2.5rem;border-bottom:1px solid var(--border);">
    <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2rem,7vw,4rem);line-height:1;letter-spacing:-.02em;color:var(--ink);margin:0 0 .75rem;">
      Projects
    </h1>
    <p style="font-size:.8rem;color:var(--muted);max-width:36rem;line-height:1.65;margin:0;">
      Side projects, AI experiments, personal tools, and creative builds.
      Things that probably shouldn't exist but do.
    </p>
  </section>

  <section style="margin-top:2.5rem;">
    <ProjectsGrid projects={projects} client:load />
  </section>
</Layout>
