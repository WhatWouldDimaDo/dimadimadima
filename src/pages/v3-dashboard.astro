---
import LayoutDashboard from '../layouts/LayoutDashboard.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects'))
  .filter(p => p.data.listed !== false)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const featured = allProjects
  .filter(p => p.data.featured)
  .map(p => ({
    slug: p.slug,
    title: p.data.title,
    tags: p.data.tags || [],
    status: p.data.status ?? 'built',
    date: p.data.date ? p.data.date.toISOString().split('T')[0] : '',
    description: p.data.description || '',
    featured: p.data.featured,
  }));

const projects = allProjects.map(p => ({
  slug: p.slug,
  title: p.data.title,
  tags: p.data.tags || [],
  status: p.data.status ?? 'built',
  date: p.data.date ? p.data.date.toISOString().split('T')[0] : '',
  description: p.data.description || '',
  featured: p.data.featured,
}));

const totalProjects = allProjects.length;

const statusCounts: Record<string, number> = {};
for (const p of allProjects) {
  const s = p.data.status || 'built';
  statusCounts[s] = (statusCounts[s] || 0) + 1;
}
---

<LayoutDashboard title="Dashboard — dimadimadima">
  <fragment slot="sidebar-left">
    <a href="/" class="sb-brand">ddd</a>

    <nav class="sb-nav">
      <a href="/v3-dashboard" class="sb-nav-link active">
        <span class="sb-nav-icon">◆</span>
        Projects
      </a>
      <a href="/resume" class="sb-nav-link">
        <span class="sb-nav-icon">▤</span>
        Resume
      </a>
      <a href="/about" class="sb-nav-link">
        <span class="sb-nav-icon">○</span>
        About
      </a>
      <a href="/feed" class="sb-nav-link">
        <span class="sb-nav-icon">≋</span>
        Feed
      </a>
    </nav>

    <div class="sb-stats">
      <div class="sb-stat-row">
        <span class="sb-stat-num">{totalProjects}</span>
        <span class="sb-stat-label">Projects</span>
      </div>
      <div class="sb-stat-row">
        <span class="sb-stat-num">178</span>
        <span class="sb-stat-label">Shows</span>
      </div>
      <div class="sb-stat-row">
        <span class="sb-stat-num">15+</span>
        <span class="sb-stat-label">Years</span>
      </div>
    </div>

    <div class="sb-projects-label">All projects</div>
    <div class="sb-project-list">
      {projects.map(p => (
        <a href={`/projects/${p.slug}`} class="sb-project-link" data-slug={p.slug}>
          {p.title}
        </a>
      ))}
    </div>
  </fragment>

  <main>
    <!-- Stats Row -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-num">{totalProjects}+</div>
        <div class="stat-label">Projects</div>
      </div>
      <div class="stat-card">
        <div class="stat-num stat-num--violet">178</div>
        <div class="stat-label">Concerts</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">15+</div>
        <div class="stat-label">Years</div>
      </div>
      <div class="stat-card">
        <div class="stat-num stat-num--green">7</div>
        <div class="stat-label">Companies</div>
      </div>
    </div>

    <!-- Project Table Section -->
    <section class="section-table">
      <div class="section-header">
        <h2 class="section-title">Project Index</h2>
      </div>

      <div class="table-controls">
        <input
          type="text"
          id="project-search"
          placeholder="Search projects..."
          class="search-input"
        />

        <div class="filter-chips" data-filter-group="status">
          <button class="chip chip--active" data-filter="all">All</button>
          <button class="chip" data-filter="live">Live</button>
          <button class="chip" data-filter="active">Active</button>
          <button class="chip" data-filter="built">Built</button>
        </div>
      </div>

      <div class="table-wrap">
        <table class="project-table">
          <thead>
            <tr>
              <th class="th-project">Project</th>
              <th class="th-tags">Tags</th>
              <th class="th-status">Status</th>
              <th class="th-date">Date</th>
            </tr>
          </thead>
          <tbody id="project-tbody">
            {projects.map(p => (
              <tr class="table-row" data-status={p.status} data-title={p.title.toLowerCase()} data-tags={p.tags.join(' ').toLowerCase()}>
                <td>
                  <a href={`/projects/${p.slug}`} class="project-link">
                    {p.title}
                  </a>
                </td>
                <td class="td-tags">
                  {p.tags.slice(0, 3).map(t => (
                    <span class="tag-pill">{t}</span>
                  ))}
                  {p.tags.length > 3 && (
                    <span class="tag-more">+{p.tags.length - 3}</span>
                  )}
                </td>
                <td>
                  <span class={'status-badge status-badge--' + p.status}>
                    {p.status}
                  </span>
                </td>
                <td class="td-date">{p.date || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Featured Projects Grid -->
    {featured.length > 0 && (
      <section class="section-featured">
        <div class="section-header">
          <h2 class="section-title">Featured</h2>
        </div>
        <div class="featured-grid">
          {featured.map(p => (
            <a href={`/projects/${p.slug}`} class="featured-card">
              <div class="featured-card-body">
                <div class="featured-status">{p.status}</div>
                <h3 class="featured-title">{p.title}</h3>
                <p class="featured-desc">{p.description}</p>
                <div class="featured-tags">
                  {p.tags.slice(0, 4).map(t => (
                    <span class="tag-pill">{t}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <fragment slot="sidebar-right">
    <div class="rs-header">Live Activity</div>

    <div class="rs-activity">
      <div class="rs-activity-item">
        <div class="rs-activity-time">Today</div>
        <div>ATL Radar — Updated event pipeline</div>
      </div>
      <div class="rs-activity-item">
        <div class="rs-activity-time">This week</div>
        <div>New project: Au Pair Research</div>
      </div>
      <div class="rs-activity-item">
        <div class="rs-activity-time">This week</div>
        <div>Resume — Added Lahzo role</div>
      </div>
      <div class="rs-activity-item">
        <div class="rs-activity-time">Recent</div>
        <div>Dive52 — 512 articles indexed</div>
      </div>
      <div class="rs-activity-item">
        <div class="rs-activity-time">Recent</div>
        <div>AI Ideas Explorer — 1,160 ideas scored</div>
      </div>
    </div>

    <div class="rs-contact">
      <div class="rs-contact-title">Get in touch</div>
      <a href="https://linkedin.com/in/dima-perkis" target="_blank" rel="noopener" class="rs-contact-link">
        <span class="rs-contact-icon">in</span>
        linkedin.com/in/dima-perkis
      </a>
      <div class="rs-contact-link">
        <span class="rs-contact-icon">◎</span>
        Atlanta, GA
      </div>
    </div>
  </fragment>
</LayoutDashboard>

<script is:inline>
  function initDashboard() {
    const searchInput = document.getElementById('project-search');
    const chips = document.querySelectorAll('.chip');
    const rows = document.querySelectorAll('.table-row');

    let activeFilter = 'all';
    let searchTerm = '';

    function filterRows() {
      const term = searchTerm.toLowerCase();
      rows.forEach(row => {
        const title = (row.getAttribute('data-title') || '');
        const tags = (row.getAttribute('data-tags') || '');
        const status = (row.getAttribute('data-status') || '');
        const matchesSearch = !term || title.includes(term) || tags.includes(term);
        const matchesFilter = activeFilter === 'all' || status === activeFilter;
        row.style.display = (matchesSearch && matchesFilter) ? '' : 'none';
      });
    }

    searchInput?.addEventListener('input', (e) => {
      searchTerm = (e.target as HTMLInputElement).value;
      filterRows();
    });

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        chips.forEach(c => c.classList.remove('chip--active'));
        chip.classList.add('chip--active');
        activeFilter = chip.getAttribute('data-filter') || 'all';
        filterRows();
      });
    });
  }

  if (typeof window !== 'undefined') {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initDashboard);
    } else {
      initDashboard();
    }
  }
</script>

<style>
  /* ─── Stats Row ─────────────────────────────── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1rem 1.25rem;
    transition: border-color 0.2s;
  }

  .stat-card:hover {
    border-color: var(--border-hi);
  }

  .stat-num {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem;
    color: var(--gold);
    line-height: 1;
  }

  .stat-num--violet {
    color: var(--violet);
  }

  .stat-num--green {
    color: #5a9a6e;
  }

  .stat-label {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-top: 0.4rem;
  }

  @media (max-width: 700px) {
    .stats-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ─── Sections ──────────────────────────────── */
  .section-table, .section-featured {
    margin-bottom: 2.5rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.25rem;
    color: var(--ink);
    margin: 0;
  }

  /* ─── Table Controls ────────────────────────── */
  .table-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .search-input {
    flex: 1;
    min-width: 180px;
    padding: 0.5rem 0.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--ink);
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .search-input::placeholder {
    color: var(--muted);
  }

  .search-input:focus {
    border-color: var(--gold);
  }

  .filter-chips {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .chip {
    font-size: 0.68rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.35em 0.75em;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: none;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.15s;
  }

  .chip:hover {
    color: var(--ink);
    border-color: var(--border-hi);
  }

  .chip--active {
    color: var(--gold);
    border-color: color-mix(in srgb, var(--gold) 40%, transparent);
    background: color-mix(in srgb, var(--gold) 8%, transparent);
  }

  /* ─── Project Table ─────────────────────────── */
  .table-wrap {
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }

  .project-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
  }

  .project-table th {
    background: var(--surface);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
    font-weight: 400;
  }

  .th-tags { width: 35%; }
  .th-status { width: 15%; }
  .th-date { width: 15%; }

  .project-table tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }

  .project-table tbody tr:last-child {
    border-bottom: none;
  }

  .project-table tbody tr:hover {
    background: color-mix(in srgb, var(--ink) 3%, transparent);
  }

  .project-table td {
    padding: 0.65rem 1rem;
    vertical-align: middle;
  }

  .project-link {
    color: var(--ink);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s;
  }

  .project-link:hover {
    color: var(--gold);
  }

  .td-tags {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .tag-pill {
    font-size: 0.62rem;
    padding: 0.15em 0.5em;
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--muted);
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .tag-pill:hover {
    color: var(--gold);
    border-color: color-mix(in srgb, var(--gold) 35%, transparent);
  }

  .tag-more {
    font-size: 0.6rem;
    color: var(--muted);
    opacity: 0.5;
  }

  .status-badge {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2em 0.55em;
    border-radius: 2px;
    display: inline-block;
  }

  .status-badge--live {
    color: #5a9a6e;
    background: color-mix(in srgb, #5a9a6e 12%, transparent);
  }

  .status-badge--active {
    color: var(--gold);
    background: color-mix(in srgb, var(--gold) 10%, transparent);
  }

  .status-badge--built {
    color: var(--muted);
    background: color-mix(in srgb, var(--muted) 10%, transparent);
  }

  .status-badge--wip {
    color: var(--violet);
    background: color-mix(in srgb, var(--violet) 12%, transparent);
  }

  .td-date {
    color: var(--muted);
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 860px) {
    .th-tags, .td-tags { display: none; }
    .project-table { font-size: 0.75rem; }
  }

  /* ─── Featured Grid ─────────────────────────── */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.75rem;
  }

  .featured-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
    display: block;
  }

  .featured-card:hover {
    border-color: var(--border-hi);
    transform: translateY(-2px);
  }

  .featured-status {
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .featured-status::before {
    content: '';
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: currentColor;
    margin-right: 0.35rem;
    vertical-align: middle;
  }

  .featured-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.1rem;
    color: var(--ink);
    margin: 0 0 0.4rem;
    line-height: 1.3;
  }

  .featured-desc {
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.55;
    margin: 0 0 0.75rem;
  }

  .featured-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
</style>
