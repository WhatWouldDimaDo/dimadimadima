---
import Layout from '../layouts/Layout.astro';

const roles = [
  {
    title:   'VP, Data & Analytics',
    company: 'Lahzo',
    period:  'Mar 2026 — Present',
    bullets: [
      'Leading data strategy and analytics infrastructure from the ground up',
      'Building AI-enabled analytics capabilities across the organization',
    ],
    metrics: [],
  },
  {
    title:   'Director, Global AI & Data Strategy',
    company: 'Equifax',
    period:  '2022 — 2026',
    bullets: [
      'Led AI maturity framework adoption across 4 international regions',
      'Restructured $14–22M in data partnerships to align with AI strategy',
      'Built cross-functional data governance and ML deployment pipelines',
    ],
    metrics: ['$14–22M partnership restructuring', 'AI maturity framework'],
  },
  {
    title:   'Senior Manager, International Analytics',
    company: 'Mailchimp',
    period:  '2019 — 2022',
    bullets: [
      'Led international expansion analytics driving 57% acquisition increase',
      'Reduced churn 40% through predictive modeling and lifecycle interventions',
    ],
    metrics: ['57% acquisition increase', '40% churn reduction'],
  },
  {
    title:   'Manager, Restructuring Analytics',
    company: 'Alvarez & Marsal',
    period:  '2017 — 2019',
    bullets: [
      'Delivered $1.5M vendor POC and $1.3M AWS cost savings for Fortune 500 clients',
    ],
    metrics: ['$1.5M vendor POC', '$1.3M AWS savings'],
  },
  {
    title:   'Consultant, AI & Customer Experience',
    company: 'Accenture Strategy',
    period:  '2014 — 2017',
    bullets: [
      'Delivered AI chatbot strategy generating $200M+ in client savings',
    ],
    metrics: ['$200M+ AI savings'],
  },
];

const skills = [
  'Data Strategy', 'AI/ML', 'Python', 'SQL', 'dbt', 'Snowflake',
  'Tableau', 'Looker', 'TypeScript', 'React', 'Astro',
  'Product Analytics', 'Team Leadership', 'ADHD Operating Systems',
];
---
<Layout title="Work">
  <section class="pt-16 pb-10 border-b border-border">
    <h1 class="font-serif text-[clamp(2.5rem,8vw,5rem)] leading-none tracking-tight text-ink mb-3">Work</h1>
    <p class="text-muted text-sm uppercase tracking-widest">Experience · Skills · Background</p>
    <p class="text-[0.7rem] text-muted/50 mt-2 italic">
      * Approximate — review and correct as needed
    </p>
  </section>

  <!-- Timeline -->
  <section class="mt-12 mb-16">
    <div class="flex flex-col gap-px bg-border border border-border">
      {roles.map((role, i) => (
        <details class="group bg-surface" open={i === 0}>
          <summary class="flex items-start justify-between p-6 cursor-pointer list-none gap-4">
            <div>
              <h3 class="font-serif text-xl text-ink group-open:text-gold transition-colors leading-tight">
                {role.title}
              </h3>
              <p class="text-sm text-muted mt-1">{role.company}</p>
            </div>
            <div class="text-right shrink-0">
              <p class="text-[0.65rem] uppercase tracking-widest text-muted">{role.period}</p>
              <span class="text-muted text-lg group-open:rotate-180 transition-transform inline-block mt-1">⌄</span>
            </div>
          </summary>

          <div class="px-6 pb-6 border-t border-border">
            <ul class="mt-4 flex flex-col gap-2">
              {role.bullets.map(b => (
                <li class="text-sm text-muted leading-relaxed flex gap-3">
                  <span class="text-gold shrink-0">—</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>

            {role.metrics.length > 0 && (
              <div class="flex gap-2 flex-wrap mt-4">
                {role.metrics.map(m => (
                  <span class="text-[0.65rem] font-mono uppercase tracking-widest border border-gold/30 text-gold px-2 py-0.5">
                    {m}
                  </span>
                ))}
              </div>
            )}
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- Skills -->
  <section class="border-t border-border pt-12">
    <h2 class="text-[0.7rem] uppercase tracking-[0.15em] text-muted mb-6">Skills & Tools</h2>
    <div class="flex gap-2 flex-wrap">
      {skills.map(s => (
        <span class="tag-pill">{s}</span>
      ))}
    </div>
  </section>
</Layout>
