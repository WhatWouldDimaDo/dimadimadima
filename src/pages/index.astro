---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const aiIdeas     = allProjects.find(p => p.slug === 'ai-ideas-explorer');

const songs = (await getCollection('posts'))
  .filter(p => !p.data.draft && p.data.type === 'song' && p.data.youtube)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const song = songs[0];

function ytId(url: string) {
  const m = url?.match(/(?:youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/watch\?v=)([^&?/\s]+)/);
  return m ? m[1] : null;
}
const songVid = song?.data.youtube ? ytId(song.data.youtube) : null;
const songThumb = songVid ? `https://img.youtube.com/vi/${songVid}/hqdefault.jpg` : null;
// NOTE: inline <iframe> player is ready to swap in, but Dima's YouTube channel has
// "Allow embedding" turned OFF (all videos 401 on oEmbed). Enable it in YouTube
// Studio, then replace the thumbnail link below with the iframe version.
---

<Layout title="Dima Perkis" description="VP, Data & AI. I build AI strategies at the enterprise level and deploy the systems that make them real. Atlanta, GA." defaultTheme="light">

  <div class="bento">

    <!-- ── INTRO ─────────────────────────────────── -->
    <div class="bc bc-intro">
      <div class="bc-eyebrow">Building since 2009</div>
      <h1 class="bc-name">Dima<br/>Perkis</h1>
      <p class="bc-bio">
        VP, Data &amp; AI. I build AI strategies at the enterprise level and deploy
        the systems that make them real — and keep building after bedtime.
      </p>
      <p class="bc-voice">
        “Every model release makes me feel like I have new superpowers.”
      </p>
      <div class="bc-tags">
        <span class="bc-tag bc-tag--gold">AI strategy</span>
        <span class="bc-tag bc-tag--violet">Deployed systems</span>
        <span class="bc-tag bc-tag--muted">Atlanta, GA</span>
      </div>
    </div>

    <!-- ── LIVE: Happening in Atlanta ─────────────── -->
    <a href="/atl" class="bc bc-live">
      <div class="bc-live-head">
        <span class="bc-live-badge"><span class="dot-pulse"></span>Live</span>
        <span class="bc-live-title">Happening in Atlanta</span>
      </div>
      <div id="atl-live-list" class="bc-live-list">
        <div class="bc-live-empty">Loading the radar…</div>
      </div>
      <div class="bc-live-foot">
        Pulled live from my event-intelligence pipeline · Full radar →
      </div>
    </a>

    <!-- ── SUNO: playable ─────────────────────────── -->
    <div class="bc bc-suno-cell">
      <div class="bc-suno-head">
        <span class="bc-music-eyebrow">♫ Suno Factory</span>
        <span class="bc-suno-name">{song?.data.title ?? 'AI songs for my kids'}</span>
      </div>
      <a
        href={song?.data.youtube ?? '/projects'}
        target="_blank"
        rel="noopener noreferrer"
        class="bc-suno-play"
      >
        {songThumb && (
          <img src={songThumb} alt={song?.data.title} class="bc-img bc-img--dim" />
        )}
        <span class="bc-play">▶</span>
      </a>
    </div>

    <!-- ── ToddlerMaps ────────────────────────────── -->
    <a href="/projects/toddlermaps" class="bc bc-project bc-tmaps">
      <img src="/images/toddlermaps/toddlermaps-overview-map.png" alt="ToddlerMaps" class="bc-img" />
      <div class="bc-project-body">
        <div class="bc-status bc-status--gold">Live</div>
        <div class="bc-project-title">ToddlerMaps</div>
        <div class="bc-project-desc">Maps of a toddler's world · AI stickers off the kitchen label printer</div>
      </div>
    </a>

    <!-- ── AI Ideas Explorer ──────────────────────── -->
    <a href="/projects/ai-ideas-explorer" class="bc bc-project bc-ideas">
      {aiIdeas?.data.image && (
        <img src={aiIdeas.data.image} alt="AI Ideas Explorer" class="bc-img" />
      )}
      <div class="bc-project-body">
        <div class="bc-status bc-status--gold">Live</div>
        <div class="bc-project-title">AI Ideas Explorer</div>
        <div class="bc-project-desc">1,160 AI business ideas, agent-generated and scored</div>
      </div>
    </a>

    <!-- ── STATS ──────────────────────────────────── -->
    <div class="bc bc-stats">
      <a href="/projects/concerts" class="bc-stats-row">
        <span class="bc-stats-n">178</span>
        <span class="bc-stats-label">shows · 18 years</span>
      </a>
      <a href="/projects/spotify-analysis" class="bc-stats-row">
        <span class="bc-stats-n bc-stats-n--violet">10,133</span>
        <span class="bc-stats-label">listening hours</span>
      </a>
    </div>

    <!-- ── CTA ───────────────────────────────────── -->
    <div class="bc bc-cta">
      <a href="/resume" class="bc-cta-row">
        <span>Professional experience</span><span class="bc-arrow">→</span>
      </a>
      <a href="/projects" class="bc-cta-row">
        <span>AI side quests</span><span class="bc-arrow">→</span>
      </a>
      <a href="/about" class="bc-cta-row">
        <span>About</span><span class="bc-arrow">→</span>
      </a>
    </div>

  </div>

  <!-- Live ATL feed: lazy-load the radar data layer after paint -->
  <script is:inline>
    (function () {
      function renderRadar() {
        try {
          var list = document.getElementById('atl-live-list');
          if (!list || typeof EVENTS === 'undefined') return;
          var today = new Date(); today.setHours(0, 0, 0, 0);
          var upcoming = EVENTS
            .filter(function (e) { return new Date(e.dateEnd || e.date) >= today; })
            .sort(function (a, b) { return (b.score || 0) - (a.score || 0); })
            .slice(0, 10)
            .sort(function (a, b) { return new Date(a.date) - new Date(b.date); })
            .slice(0, 4);
          if (!upcoming.length) return;
          list.innerHTML = upcoming.map(function (e) {
            return '<div class="bc-live-row">'
              + '<span class="bc-live-date">' + e.dateStr + '</span>'
              + '<span class="bc-live-event"><span class="bc-live-name">' + e.title + '</span>'
              + '<span class="bc-live-venue">' + (e.venue || '') + '</span></span>'
              + '<span class="bc-live-tier bc-live-tier--' + (e.tier || 'B') + '">' + (e.tier || '') + '</span>'
              + '</div>';
          }).join('');
        } catch (err) { /* leave fallback text */ }
      }
      function loadRadar() {
        var s = document.createElement('script');
        s.src = '/atl/data.js';
        s.onload = renderRadar;
        document.body.appendChild(s);
      }
      if ('requestIdleCallback' in window) requestIdleCallback(loadRadar);
      else setTimeout(loadRadar, 250);
    })();
  </script>

</Layout>

<style>
  /* ─── Grid ──────────────────────────────────────── */
  .bento {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: 350px 280px 200px;
    gap: 0.625rem;
    padding-top: 1.75rem;
    padding-bottom: 4rem;
  }

  /* ─── Base cell ─────────────────────────────────── */
  .bc {
    background: var(--surface);
    border: 1px solid var(--border);
    overflow: hidden;
    position: relative;
    transition: border-color 0.2s ease;
  }
  a.bc {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  a.bc:hover { border-color: var(--border-hi); }

  /* ─── Grid placement ────────────────────────────── */
  .bc-intro     { grid-column: 1 / 4; grid-row: 1; }
  .bc-live      { grid-column: 4 / 7; grid-row: 1; }
  .bc-suno-cell { grid-column: 1 / 4; grid-row: 2; }
  .bc-tmaps     { grid-column: 4 / 7; grid-row: 2; }
  .bc-ideas     { grid-column: 1 / 4; grid-row: 3; }
  .bc-stats     { grid-column: 4 / 6; grid-row: 3; }
  .bc-cta       { grid-column: 6;     grid-row: 3; }

  /* ─── Shared image pattern ──────────────────────── */
  .bc-img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }
  a.bc:hover .bc-img { transform: scale(1.05); }

  /* ─── INTRO ─────────────────────────────────────── */
  .bc-intro {
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .bc-eyebrow {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
  }
  .bc-name {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
  }
  .bc-bio {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }
  .bc-voice {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 0.95rem;
    color: var(--gold);
    line-height: 1.5;
    margin: 0;
  }
  .bc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .bc-tag {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.2em 0.65em;
    border: 1px solid var(--border);
    font-family: 'DM Mono', monospace;
  }
  .bc-tag--gold   { color: var(--gold);   border-color: color-mix(in srgb, var(--gold) 30%, transparent); }
  .bc-tag--violet { color: var(--violet); border-color: color-mix(in srgb, var(--violet) 30%, transparent); }
  .bc-tag--muted  { color: var(--muted); }

  /* ─── LIVE ATL ──────────────────────────────────── */
  .bc-live {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.5rem;
  }
  .bc-live-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.9rem;
  }
  .bc-live-badge {
    font-size: 0.56rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #5a9a6e;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .dot-pulse {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #5a9a6e;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .bc-live-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.15rem;
    color: var(--ink);
  }
  .bc-live-list {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.15rem;
    min-height: 0;
  }
  .bc-live-empty {
    font-size: 0.72rem;
    font-family: 'DM Mono', monospace;
    color: var(--muted);
    opacity: 0.6;
  }
  .bc-live :global(.bc-live-row) {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .bc-live :global(.bc-live-row:last-child) { border-bottom: none; }
  .bc-live :global(.bc-live-date) {
    font-size: 0.62rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gold);
    flex-shrink: 0;
    width: 5.2em;
  }
  .bc-live :global(.bc-live-event) {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }
  .bc-live :global(.bc-live-name) {
    font-size: 0.82rem;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bc-live :global(.bc-live-venue) {
    font-size: 0.62rem;
    font-family: 'DM Mono', monospace;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bc-live :global(.bc-live-tier) {
    margin-left: auto;
    flex-shrink: 0;
    font-size: 0.6rem;
    font-family: 'DM Mono', monospace;
    padding: 0.1em 0.55em;
    border: 1px solid var(--border);
    color: var(--muted);
  }
  .bc-live :global(.bc-live-tier--S) { color: var(--gold);   border-color: color-mix(in srgb, var(--gold) 45%, transparent); }
  .bc-live :global(.bc-live-tier--A) { color: var(--violet); border-color: color-mix(in srgb, var(--violet) 40%, transparent); }
  .bc-live-foot {
    font-size: 0.62rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    opacity: 0.55;
    margin-top: 0.9rem;
    transition: opacity 0.15s, color 0.15s;
  }
  a.bc-live:hover .bc-live-foot { opacity: 1; color: var(--gold); }

  /* ─── SUNO ──────────────────────────────────────── */
  .bc-suno-cell {
    display: flex;
    flex-direction: column;
  }
  .bc-suno-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--border);
    min-width: 0;
  }
  .bc-music-eyebrow {
    font-size: 0.63rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gold);
    flex-shrink: 0;
  }
  .bc-suno-name {
    font-family: 'DM Serif Display', serif;
    font-size: 0.95rem;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bc-suno-play {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    min-height: 0;
  }
  .bc-suno-play .bc-img { position: absolute; inset: 0; }
  .bc-img--dim { filter: brightness(0.55); }
  .bc-suno-play:hover .bc-img--dim { filter: brightness(0.7); }
  .bc-play {
    position: relative;
    z-index: 1;
    width: 54px; height: 54px;
    border-radius: 50%;
    background: rgba(212,168,83,0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000;
    font-size: 1rem;
    padding-left: 4px;
    transition: background 0.2s, transform 0.2s;
  }
  .bc-suno-play:hover .bc-play { background: var(--gold); transform: scale(1.1); }

  .bc-tmaps .bc-img { object-position: center; }

  /* ─── PROJECT CARDS ─────────────────────────────── */
  .bc-project-body {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(12,12,14,0.97) 55%, transparent 100%);
    padding: 0.85rem 1.1rem;
  }
  .bc-status {
    font-size: 0.52rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 0.2rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .bc-status--gold { color: var(--gold); }
  .bc-status--gold::before {
    content: '';
    display: inline-block;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: currentColor;
  }
  .bc-project-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1rem;
    color: rgba(240, 236, 228, 0.95);
    line-height: 1.2;
  }
  .bc-project-desc {
    font-size: 0.7rem;
    color: rgba(240, 236, 228, 0.6);
    margin-top: 0.2rem;
    font-family: 'DM Mono', monospace;
    line-height: 1.45;
  }

  /* ─── STATS ─────────────────────────────────────── */
  .bc-stats {
    display: flex;
    flex-direction: column;
  }
  .bc-stats-row {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0 1.5rem;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }
  .bc-stats-row:last-child { border-bottom: none; }
  .bc-stats-row:hover { background: color-mix(in srgb, var(--gold) 5%, transparent); }
  .bc-stats-n {
    font-family: 'DM Serif Display', serif;
    font-size: 1.7rem;
    color: var(--gold);
    line-height: 1;
  }
  .bc-stats-n--violet { color: var(--violet); }
  .bc-stats-label {
    font-size: 0.65rem;
    font-family: 'DM Mono', monospace;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ─── CTA ───────────────────────────────────────── */
  .bc-cta {
    display: flex;
    flex-direction: column;
    border-left: 2px solid var(--gold);
  }
  .bc-cta-row {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0 1rem;
    text-decoration: none;
    color: var(--muted);
    font-size: 0.66rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s, background 0.15s;
  }
  .bc-cta-row:last-child { border-bottom: none; }
  .bc-cta-row:hover {
    color: var(--gold);
    background: color-mix(in srgb, var(--gold) 6%, transparent);
  }
  .bc-arrow {
    opacity: 0.35;
    transition: opacity 0.15s, transform 0.15s;
  }
  .bc-cta-row:hover .bc-arrow { opacity: 1; transform: translateX(3px); }

  /* ─── MOBILE ────────────────────────────────────── */
  @media (max-width: 860px) {
    .bento {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      gap: 0.5rem;
    }
    .bc-intro, .bc-live, .bc-suno-cell, .bc-tmaps,
    .bc-ideas, .bc-stats, .bc-cta {
      grid-column: 1;
      grid-row: auto;
    }
    .bc-intro     { order: 1; min-height: 300px; }
    .bc-live      { order: 2; min-height: 320px; }
    .bc-suno-cell { order: 3; min-height: 280px; }
    .bc-tmaps     { order: 4; min-height: 220px; }
    .bc-ideas     { order: 5; min-height: 220px; }
    .bc-stats     { order: 6; min-height: 140px; }
    .bc-cta       { order: 7; min-height: 150px; }
  }
</style>
