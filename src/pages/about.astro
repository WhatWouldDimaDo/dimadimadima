---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About" description="Dima Perkis — VP, Data & AI. Systems builder, ADHD brain, husband to Jeannie, father of Dean & Ruby.">

  <!-- Hero -->
  <section style="padding-top:4rem;padding-bottom:3rem;border-bottom:1px solid var(--border);">
    <div style="display:flex;align-items:flex-start;gap:3rem;flex-wrap:wrap;">
      <div style="flex:1;min-width:min(100%,320px);">
        <p style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--gold);margin:0 0 1rem;">About</p>
        <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2.5rem,7vw,4.5rem);line-height:1.05;letter-spacing:-.02em;color:var(--ink);margin:0 0 1.5rem;">
          Professional.<br/>
          <span style="color:var(--violet);">Side quests.</span><br/>
          <span style="color:var(--muted);">Personal.</span>
        </h1>
        <p style="font-size:.95rem;color:var(--muted);line-height:1.75;max-width:36rem;margin:0;">
          I build AI strategies at the enterprise level and deploy the systems that make them real.
          Most recently VP of Strategy & Analytics at an AI startup; before that Equifax, Mailchimp,
          Accenture, A&M, and Booz Allen. Father of Dean & Ruby. Everesting finisher.
          Compulsive builder of things that probably shouldn't exist.
        </p>
        <p style="font-size:.85rem;color:var(--gold);font-style:italic;margin:1rem 0 0;">
          "To make a stranger laugh every day."
        </p>
      </div>
      <div style="flex-shrink:0;">
        <img src="/images/dima.jpeg" alt="Dima Perkis"
          style="width:min(360px,80vw);height:auto;aspect-ratio:4/5;border-radius:12px;object-fit:cover;border:2px solid var(--border);" />
      </div>
    </div>
  </section>

  <!-- Three-panel strip -->
  <section style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,260px),1fr));gap:1rem;margin-top:2.5rem;margin-bottom:3rem;">
    <div style="background:var(--surface);padding:2rem;border:1px solid var(--border);">
      <p style="font-size:.65rem;text-transform:uppercase;letter-spacing:.15em;color:var(--gold);margin:0 0 .75rem;">Professional</p>
      <p style="font-family:'DM Serif Display',serif;font-size:1.15rem;color:var(--ink);line-height:1.4;margin:0 0 .75rem;">Analytics leadership + AI strategy</p>
      <p style="font-size:.85rem;color:var(--muted);line-height:1.65;margin:0;">
        15+ years scaling analytics orgs and leading cross-functional teams — from Board rooms to front-line teams. Most recently VP at an AI startup; previously Equifax, Mailchimp, Accenture, A&M, Booz Allen.
      </p>
    </div>
    <div style="background:var(--surface);padding:2rem;border:1px solid var(--border);">
      <p style="font-size:.65rem;text-transform:uppercase;letter-spacing:.15em;color:var(--violet);margin:0 0 .75rem;">Side Quests</p>
      <p style="font-family:'DM Serif Display',serif;font-size:1.15rem;color:var(--ink);line-height:1.4;margin:0 0 .75rem;">Building after bedtime</p>
      <p style="font-size:.85rem;color:var(--muted);line-height:1.65;margin:0;">
        AI tools, data visualizations, automation pipelines, creative experiments. Projects, explorations, and ideas — some shipped, some half-baked, all interesting.
      </p>
    </div>
    <div style="background:var(--surface);padding:2rem;border:1px solid var(--border);">
      <p style="font-size:.65rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin:0 0 .75rem;">Personal</p>
      <p style="font-family:'DM Serif Display',serif;font-size:1.15rem;color:var(--ink);line-height:1.4;margin:0 0 .75rem;">Husband, father, concert-goer, learner</p>
      <p style="font-size:.85rem;color:var(--muted);line-height:1.65;margin:0;">
        Married to Jeannie, who deserves public credit for her patience with my dad jokes and
        the endless parade of apps I make her beta-test. Dad to Dean & Ruby. 29029 Everesting
        finisher. Concert obsessive. Born in Moldova, raised in New Jersey, rooted in Atlanta.
      </p>
    </div>
  </section>

  <!-- Core values -->
  <section style="margin-bottom:3rem;">
    <h2 style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin-bottom:1.25rem;">Core Values</h2>
    <div style="display:flex;flex-wrap:wrap;gap:.75rem;">
      {[
        'Family & Security',
        'Joy, Awe & Adventure',
        'Growth & Curiosity',
        'Physical Vitality',
        'Resilience',
        'Contribution',
      ].map(v => (
        <span style="font-family:'DM Serif Display',serif;font-size:.95rem;color:var(--ink);background:var(--surface);border:1px solid var(--border);padding:.6rem 1.25rem;">
          {v}
        </span>
      ))}
    </div>
  </section>

  <!-- Bucket list -->
  <section style="margin-bottom:3rem;">
    <h2 style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin-bottom:1.25rem;">Bucket List</h2>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
      <div style="background:var(--surface);padding:2rem;border:1px solid var(--border);">
        <p style="font-size:.65rem;text-transform:uppercase;letter-spacing:.12em;color:var(--gold);margin:0 0 .75rem;">Done</p>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.5rem;">
          {[
            '29029 Everesting',
            'Travel through Southeast Asia',
            'Motorcycle trips across Colombia',
          ].map(b => (
            <li style="font-size:.85rem;color:var(--gold);display:flex;gap:.5rem;">
              <span style="flex-shrink:0;">&#10003;</span><span style="text-decoration:line-through;opacity:.8;">{b}</span>
            </li>
          ))}
        </ul>
      </div>
      <div style="background:var(--surface);padding:2rem;border:1px solid var(--border);">
        <p style="font-size:.65rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin:0 0 .75rem;">Next</p>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.5rem;">
          {[
            'Antarctica + aurora borealis',
            'Camino de Santiago',
            'Stand-up comedy set (actually good)',
            'Knife from scratch, woodworking',
            'Burning Man',
            'Scuba — Great Barrier Reef',
            'Hut-to-hut hike with the kids',
            'Ultra marathon',
            'Publish a book',
            'Safari with Jeannie',
            'Dog sledding — Alaska or Scandinavia',
          ].map(b => (
            <li style="font-size:.85rem;color:var(--muted);display:flex;gap:.5rem;">
              <span style="color:var(--border-hi);flex-shrink:0;">&#9675;</span>{b}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section style="border-top:1px solid var(--border);padding-top:2.5rem;margin-bottom:2rem;">
    <h2 style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin-bottom:1.5rem;">Get in Touch</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,240px),1fr));gap:1px;border:1px solid var(--border);background:var(--border);">
      {[
        { label: 'LinkedIn', value: 'linkedin.com/in/dima-perkis', href: 'https://linkedin.com/in/dima-perkis' },
        { label: 'Email', value: 'dperkis@gmail.com', href: 'mailto:dperkis@gmail.com' },
        { label: 'Best for', value: 'AI strategy, analytics leadership, building something interesting together', href: null },
      ].map(c => (
        <div style="background:var(--surface);padding:1.25rem 1.5rem;">
          <p style="font-size:.6rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin:0 0 .4rem;">{c.label}</p>
          {c.href ? (
            <a href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined}
              style="font-size:.8rem;color:var(--gold);text-decoration:none;transition:opacity .15s;" onmouseover="this.style.opacity='.7'" onmouseout="this.style.opacity='1'">
              {c.value} ↗
            </a>
          ) : (
            <p style="font-size:.8rem;color:var(--ink);margin:0;line-height:1.5;">{c.value}</p>
          )}
        </div>
      ))}
    </div>
  </section>

</Layout>
