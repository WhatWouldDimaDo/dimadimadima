---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .filter(p => p.data.featured);

const recentPosts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const TYPE_ICONS: Record<string, string> = {
  song: '♫', image: '◈', project: '⌥', note: '◇',
};
---
<Layout>
  <!-- Hero -->
  <section class="pt-20 pb-16 border-b border-border animate-fade-up">
    <h1 class="font-serif text-[clamp(3.5rem,12vw,8rem)] leading-none tracking-tight text-ink mb-4">
      dima<span class="text-gold italic">·</span>dima<span class="text-gold italic">·</span>dima
    </h1>
    <p class="text-muted text-sm uppercase tracking-widest font-light">
      VP Data & Analytics · Systems Thinker · Builder of Odd Things
    </p>
  </section>

  <!-- Projects -->
  <section class="mt-16 mb-20">
    <h2 class="text-[0.7rem] uppercase tracking-[0.15em] text-muted mb-6">Selected Projects</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-border border border-border">
      {projects.map(p => (
        <ProjectCard
          title={p.data.title}
          description={p.data.description}
          tags={p.data.tags}
          url={p.data.url}
          github={p.data.github}
        />
      ))}
    </div>
  </section>

  <!-- Recent feed -->
  <section class="border-t border-border pt-16">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-[0.7rem] uppercase tracking-[0.15em] text-muted">Latest</h2>
      <a href="/feed" class="text-[0.7rem] text-muted hover:text-gold transition-colors uppercase tracking-widest">
        All posts →
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-border border border-border">
      {recentPosts.map(post => {
        const icon = TYPE_ICONS[post.data.type] ?? '◇';
        const color = post.data.type === 'song' ? '#d4a853'
                    : post.data.type === 'image' ? '#7c6fcd'
                    : post.data.type === 'project' ? '#5a9a6e'
                    : '#6b6a72';
        const date = post.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
        return (
          <div class="bg-surface p-6 flex flex-col gap-3">
            <div class="flex items-center justify-between">
              <span class="text-xs uppercase tracking-widest" style={`color:${color}`}>{icon} {post.data.type}</span>
              <span class="text-muted text-[0.65rem]">{date}</span>
            </div>
            <h3 class="font-serif text-xl text-ink leading-tight">{post.data.title}</h3>
            {post.data.caption && <p class="text-muted text-sm leading-relaxed">{post.data.caption}</p>}
            {post.data.youtube && (
              <a href={post.data.youtube} target="_blank" rel="noopener"
                 class="text-xs text-muted hover:text-gold transition-colors mt-auto pt-3 border-t border-border flex items-center gap-2">
                <span style="color:#ff4444">▶</span> Watch on YouTube ↗
              </a>
            )}
          </div>
        );
      })}
    </div>
  </section>

  <!-- About strip -->
  <section class="mt-20 pt-16 border-t border-border">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-px border border-border bg-border">
      <div class="bg-surface p-6">
        <p class="text-[0.65rem] uppercase tracking-widest text-muted mb-2">Currently</p>
        <p class="text-sm text-ink">VP, Data & Analytics at <span class="text-gold">Lahzo</span></p>
      </div>
      <div class="bg-surface p-6">
        <p class="text-[0.65rem] uppercase tracking-widest text-muted mb-2">Interested in</p>
        <p class="text-sm text-ink">AI systems, personal data, building things that shouldn't exist</p>
      </div>
      <div class="bg-surface p-6">
        <p class="text-[0.65rem] uppercase tracking-widest text-muted mb-2">Base</p>
        <p class="text-sm text-ink">Atlanta, GA · Father of Dean & Ruby</p>
      </div>
    </div>
  </section>
</Layout>
