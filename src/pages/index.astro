---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const featured = (await getCollection('projects'))
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const aiIdeas  = featured.find(p => p.slug === 'ai-ideas-explorer');
const atlRadar = featured.find(p => p.slug === 'atl-radar');
const dive52   = featured.find(p => p.slug === 'dive52');
const concerts = featured.find(p => p.slug === 'concerts');

// Also pull a few non-featured projects with good images for bento cells
const allProjects = await getCollection('projects');
const lilMimic = allProjects.find(p => p.slug === 'lil-mimic');

const songs = (await getCollection('posts'))
  .filter(p => !p.data.draft && p.data.type === 'song' && p.data.youtube)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const song = songs[0];

function ytId(url: string) {
  const m = url?.match(/(?:youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/watch\?v=)([^&?/\s]+)/);
  return m ? m[1] : null;
}
const songVid   = song?.data.youtube ? ytId(song.data.youtube) : null;
const songThumb = songVid ? `https://img.youtube.com/vi/${songVid}/hqdefault.jpg` : null;
---

<Layout title="Dima Perkis" description="VP Strategy & Analytics. Builder of AI systems and odd experiments. 30+ projects shipped. Atlanta, GA." defaultTheme="light">

  <div class="bento">

    <!-- ── INTRO ─────────────────────────────────── -->
    <div class="bc bc-intro">
      <div class="bc-eyebrow">Building since 2009</div>
      <h1 class="bc-name">Dima<br/>Perkis</h1>
      <p class="bc-bio">
        VP Strategy &amp; Analytics at Lahzo. Building AI systems and data pipelines
        after bedtime. 30+ projects shipped.
      </p>
      <div class="bc-tags">
        <span class="bc-tag bc-tag--gold">AI builder</span>
        <span class="bc-tag bc-tag--violet">Data systems</span>
        <span class="bc-tag bc-tag--muted">Atlanta, GA</span>
      </div>
      <nav class="bc-nav">
        <a href="/projects">Projects</a>
        <a href="/resume">Resume</a>
        <a href="/feed">Feed</a>
        <a href="/about">About</a>
      </nav>
    </div>

    <!-- ── ART ───────────────────────────────────── -->
    <div class="bc bc-art">
      <img src="/images/family-tarot.png" alt="AI-generated family tarot cards" loading="eager" />
      <div class="bc-art-cap">Architect of Joy · Queen of Insight · Child of Wonders</div>
    </div>

    <!-- ── STAT: Concerts ─────────────────────────── -->
    <a href="/projects/concerts" class="bc bc-stat bc-stat-concerts">
      <div class="bc-stat-n">178</div>
      <div class="bc-stat-label">shows · 18 years</div>
      <div class="bc-stat-hint">Concert history ↗</div>
    </a>

    <!-- ── STAT: Spotify ──────────────────────────── -->
    <a href="/projects/spotify-analysis" class="bc bc-stat bc-stat-spotify">
      <div class="bc-stat-n bc-stat-n--violet">10,133</div>
      <div class="bc-stat-label">listening hours</div>
      <div class="bc-stat-hint">Spotify analysis ↗</div>
    </a>

    <!-- ── HERO: AI Ideas Explorer ────────────────── -->
    <a href="/projects/ai-ideas-explorer" class="bc bc-hero">
      {aiIdeas?.data.image && (
        <img src={aiIdeas.data.image} alt="AI Ideas Galaxy" class="bc-img" loading="eager" />
      )}
      <div class="bc-hero-overlay">
        <div class="bc-live-dot">
          <span class="dot-pulse"></span>Live
        </div>
        <div class="bc-hero-stat">1,160 ideas · 28 industries · 6 scoring rounds</div>
        <h2 class="bc-hero-title">AI Ideas Explorer</h2>
        <p class="bc-hero-desc">
          Agentic idea generation at scale. Claude agents produce and score 1,160 AI
          business ideas — filtered by novelty, moat, and market size.
        </p>
      </div>
    </a>

    <!-- ── ATL Radar ──────────────────────────────── -->
    <a href="/projects/atl-radar" class="bc bc-project bc-atl">
      {atlRadar?.data.image && (
        <img src={atlRadar.data.image} alt="ATL Radar" class="bc-img" />
      )}
      <div class="bc-project-body">
        <div class="bc-status bc-status--gold">Active</div>
        <div class="bc-project-title">ATL Radar</div>
        <div class="bc-project-desc">Personal event intelligence for Atlanta</div>
      </div>
    </a>

    <!-- ── Dive52 ──────────────────────────────────── -->
    <a href="/projects/dive52" class="bc bc-project bc-dive">
      {dive52?.data.image && (
        <img src={dive52.data.image} alt="Dive52" class="bc-img" />
      )}
      <div class="bc-project-body">
        <div class="bc-status bc-status--gold">Active</div>
        <div class="bc-project-title">Dive52</div>
        <div class="bc-project-desc">ADHD knowledge retention · 512 articles</div>
      </div>
    </a>

    <!-- ── Lil Mimic ─────────────────────────────────── -->
    <a href="/projects/lil-mimic" class="bc bc-project bc-suno">
      {lilMimic?.data.image && (
        <img src={lilMimic.data.image} alt="Lil Mimic" class="bc-img" />
      )}
      <div class="bc-project-body">
        <div class="bc-status bc-status--gold">Live</div>
        <div class="bc-project-title">Lil' Mimic Studio</div>
        <div class="bc-project-desc">AI comic creator · toddler to cartoon</div>
      </div>
    </a>

    <!-- ── Concert History ────────────────────────── -->
    <a href="/projects/concerts" class="bc bc-project bc-concert">
      {concerts?.data.image && (
        <img src={concerts.data.image} alt="Concert History" class="bc-img" />
      )}
      <div class="bc-project-body">
        <div class="bc-project-title">Concert History</div>
        <div class="bc-project-desc">178 shows · 18 years of data</div>
      </div>
    </a>

    <!-- ── Music ──────────────────────────────────── -->
    <a
      href={song?.data.youtube ?? '/feed'}
      target={song?.data.youtube ? '_blank' : undefined}
      rel="noopener noreferrer"
      class="bc bc-music"
    >
      {songThumb ? (
        <img src={songThumb} alt={song?.data.title} class="bc-img bc-img--dim" />
      ) : (
        <div class="bc-music-bg">♫</div>
      )}
      <div class="bc-music-overlay">
        <div class="bc-play">▶</div>
        <div>
          <div class="bc-music-eyebrow">♫ Latest</div>
          <div class="bc-music-title">{song?.data.title ?? 'Suno Factory'}</div>
        </div>
      </div>
    </a>

    <!-- ── Spotify Stats ──────────────────────────── -->
    <a href="/projects/spotify-analysis" class="bc bc-spotify">
      <div>
        <div class="bc-sptf-n">147,594</div>
        <div class="bc-sptf-label">streams · 14 years</div>
      </div>
      <div class="bc-sptf-sub">15,748 unique artists · 10,133 hrs</div>
      <div class="bc-sptf-cta">Full analysis ↗</div>
    </a>

    <!-- ── CTA ───────────────────────────────────── -->
    <div class="bc bc-cta">
      <a href="/projects" class="bc-cta-row">
        <span>All projects</span><span class="bc-arrow">→</span>
      </a>
      <a href="/feed" class="bc-cta-row">
        <span>The feed</span><span class="bc-arrow">→</span>
      </a>
      <a href="/resume" class="bc-cta-row">
        <span>Resume</span><span class="bc-arrow">→</span>
      </a>
      <a href="/about" class="bc-cta-row">
        <span>About</span><span class="bc-arrow">→</span>
      </a>
    </div>

  </div>

</Layout>

<style>
  /* ─── Grid ──────────────────────────────────────── */
  .bento {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: 165px 165px 270px 205px 205px;
    gap: 0.625rem;
    padding-top: 1.75rem;
    padding-bottom: 4rem;
  }

  /* ─── Base cell ─────────────────────────────────── */
  .bc {
    background: var(--surface);
    border: 1px solid var(--border);
    overflow: hidden;
    position: relative;
    transition: border-color 0.2s ease;
  }
  a.bc {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  a.bc:hover { border-color: var(--border-hi); }

  /* ─── Grid placement ────────────────────────────── */
  .bc-intro   { grid-column: 1 / 4; grid-row: 1 / 3; }
  .bc-art     { grid-column: 4 / 6; grid-row: 1 / 3; }
  .bc-stat-concerts { grid-column: 6;     grid-row: 1;     }
  .bc-stat-spotify  { grid-column: 6;     grid-row: 2;     }
  .bc-hero    { grid-column: 1 / 5; grid-row: 3;     }
  .bc-atl     { grid-column: 5 / 7; grid-row: 3;     }
  .bc-dive    { grid-column: 1 / 3; grid-row: 4;     }
  .bc-suno    { grid-column: 3 / 5; grid-row: 4;     }
  .bc-concert { grid-column: 5 / 7; grid-row: 4;     }
  .bc-music   { grid-column: 1 / 4; grid-row: 5;     }
  .bc-spotify { grid-column: 4 / 6; grid-row: 5;     }
  .bc-cta     { grid-column: 6;     grid-row: 5;     }

  /* ─── Shared image pattern ──────────────────────── */
  .bc-img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }
  a.bc:hover .bc-img { transform: scale(1.05); }
  .bc-img--dim { filter: brightness(0.55); }
  a.bc:hover .bc-img--dim { filter: brightness(0.7); }

  /* ─── INTRO ─────────────────────────────────────── */
  .bc-intro {
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .bc-eyebrow {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
  }
  .bc-name {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
  }
  .bc-bio {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }
  .bc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .bc-tag {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.2em 0.65em;
    border: 1px solid var(--border);
    font-family: 'DM Mono', monospace;
  }
  .bc-tag--gold   { color: var(--gold);   border-color: color-mix(in srgb, var(--gold) 30%, transparent); }
  .bc-tag--violet { color: var(--violet); border-color: color-mix(in srgb, var(--violet) 30%, transparent); }
  .bc-tag--muted  { color: var(--muted); }
  .bc-nav {
    display: flex;
    gap: 1.25rem;
  }
  .bc-nav a {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-decoration: none;
    font-family: 'DM Mono', monospace;
    transition: color 0.15s;
  }
  .bc-nav a:hover { color: var(--gold); }

  /* ─── ART ───────────────────────────────────────── */
  .bc-art img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .bc-art:hover img { transform: scale(1.03); }
  .bc-art-cap {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 0.5rem 0.75rem;
    background: linear-gradient(to top, rgba(12,12,14,0.88) 0%, transparent 100%);
    font-size: 0.52rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(232,230,224,0.35);
  }

  /* ─── STAT ──────────────────────────────────────── */
  .bc-stat {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .bc-stat-n {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem;
    line-height: 1;
    color: var(--gold);
  }
  .bc-stat-n--violet { color: var(--violet); }
  .bc-stat-label {
    font-size: 0.65rem;
    font-family: 'DM Mono', monospace;
    color: var(--muted);
    margin-top: 0.3rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .bc-stat-hint {
    font-size: 0.62rem;
    font-family: 'DM Mono', monospace;
    color: var(--muted);
    margin-top: 0.5rem;
    opacity: 0.4;
    transition: opacity 0.15s, color 0.15s;
  }
  a.bc-stat:hover .bc-stat-hint { opacity: 1; color: var(--gold); }

  /* ─── HERO ──────────────────────────────────────── */
  .bc-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(12,12,14,0.97) 28%, rgba(12,12,14,0.08) 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.75rem 2rem;
    transition: background 0.35s ease;
  }
  a.bc-hero:hover .bc-hero-overlay {
    background: linear-gradient(to top, rgba(12,12,14,0.99) 35%, rgba(12,12,14,0.12) 100%);
  }
  .bc-live-dot {
    font-size: 0.56rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #5a9a6e;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.4rem;
  }
  .dot-pulse {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #5a9a6e;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .bc-hero-stat {
    font-size: 0.67rem;
    font-family: 'DM Mono', monospace;
    color: color-mix(in srgb, var(--gold) 70%, transparent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .bc-hero-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.3rem, 2.4vw, 1.9rem);
    color: #fff;
    line-height: 1.15;
    margin: 0 0 0.4rem;
  }
  .bc-hero-desc {
    font-size: 0.82rem;
    color: rgba(232,230,224,0.55);
    line-height: 1.6;
    margin: 0;
    max-width: 30rem;
  }

  /* ─── PROJECT CARDS ─────────────────────────────── */
  .bc-project-body {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(12,12,14,0.97) 55%, transparent 100%);
    padding: 0.85rem 1.1rem;
  }
  .bc-project-body--full {
    position: relative;
    background: none;
    height: 100%;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .bc-status {
    font-size: 0.52rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 0.2rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .bc-status--gold { color: var(--gold); }
  .bc-status--gold::before {
    content: '';
    display: inline-block;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: currentColor;
  }
  .bc-project-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1rem;
    color: rgba(240, 236, 228, 0.95);
    line-height: 1.2;
  }
  .bc-project-desc {
    font-size: 0.7rem;
    color: rgba(240, 236, 228, 0.6);
    margin-top: 0.2rem;
    font-family: 'DM Mono', monospace;
    line-height: 1.45;
  }
  .bc-project-meta {
    font-size: 0.58rem;
    color: var(--gold);
    margin-top: 0.5rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ─── MUSIC ─────────────────────────────────────── */
  .bc-music-bg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    color: var(--gold);
    opacity: 0.07;
  }
  .bc-music-overlay {
    position: absolute; inset: 0;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem;
  }
  .bc-play {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(212,168,83,0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000;
    font-size: 0.9rem;
    flex-shrink: 0;
    padding-left: 3px;
    transition: background 0.2s, transform 0.2s;
  }
  a.bc-music:hover .bc-play { background: var(--gold); transform: scale(1.08); }
  .bc-music-eyebrow {
    font-size: 0.63rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gold);
    margin-bottom: 0.3rem;
  }
  .bc-music-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.1rem;
    color: var(--ink);
    line-height: 1.2;
  }
  /* When there IS a thumbnail, the overlay text needs to be white */
  .bc-music:has(.bc-img) .bc-music-title { color: #fff; }

  /* ─── SPOTIFY ───────────────────────────────────── */
  .bc-spotify {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-decoration: none;
    color: inherit;
  }
  .bc-sptf-n {
    font-family: 'DM Serif Display', serif;
    font-size: 1.9rem;
    color: var(--violet);
    line-height: 1;
  }
  .bc-sptf-label {
    font-size: 0.67rem;
    font-family: 'DM Mono', monospace;
    color: var(--muted);
    margin-top: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .bc-sptf-sub {
    font-size: 0.7rem;
    font-family: 'DM Mono', monospace;
    color: var(--muted);
    opacity: 0.6;
    line-height: 1.5;
  }
  .bc-sptf-cta {
    font-size: 0.67rem;
    font-family: 'DM Mono', monospace;
    color: var(--violet);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
    transition: opacity 0.15s;
  }
  a.bc-spotify:hover .bc-sptf-cta { opacity: 1; }

  /* ─── CTA ───────────────────────────────────────── */
  .bc-cta {
    display: flex;
    flex-direction: column;
    border-left: 2px solid var(--gold);
  }
  .bc-cta-row {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1rem;
    text-decoration: none;
    color: var(--muted);
    font-size: 0.72rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s, background 0.15s;
  }
  .bc-cta-row:last-child { border-bottom: none; }
  .bc-cta-row:hover {
    color: var(--gold);
    background: color-mix(in srgb, var(--gold) 6%, transparent);
  }
  .bc-arrow {
    opacity: 0.35;
    transition: opacity 0.15s, transform 0.15s;
  }
  .bc-cta-row:hover .bc-arrow { opacity: 1; transform: translateX(3px); }

  /* ─── MOBILE: 2 cols ────────────────────────────── */
  @media (max-width: 860px) {
    .bento {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
    }
    /* Reset all explicit placement */
    .bc-intro, .bc-art, .bc-stat-concerts, .bc-stat-spotify,
    .bc-hero, .bc-atl, .bc-dive, .bc-suno, .bc-concert,
    .bc-music, .bc-spotify, .bc-cta {
      grid-column: auto;
      grid-row: auto;
    }
    /* Priority ordering */
    .bc-intro          { order: 1; grid-column: 1 / 3; min-height: 280px; }
    .bc-hero           { order: 2; grid-column: 1 / 3; min-height: 240px; }
    .bc-atl            { order: 3; grid-column: 1 / 3; min-height: 200px; }
    .bc-art            { order: 4; grid-column: 1 / 3; min-height: 220px; }
    .bc-dive           { order: 5; grid-column: 1;     min-height: 180px; }
    .bc-suno           { order: 6; grid-column: 2;     min-height: 180px; }
    .bc-concert        { order: 7; grid-column: 1 / 3; min-height: 180px; }
    .bc-stat-concerts  { order: 8; grid-column: 1;     min-height: 120px; }
    .bc-stat-spotify   { order: 9; grid-column: 2;     min-height: 120px; }
    .bc-music          { order: 10; grid-column: 1 / 3; min-height: 180px; }
    .bc-spotify        { order: 11; grid-column: 1 / 3; min-height: 140px; }
    .bc-cta            { order: 12; grid-column: 1 / 3; min-height: 160px; }
  }

  /* ─── MOBILE: 1 col ─────────────────────────────── */
  @media (max-width: 480px) {
    .bento {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .bc-intro, .bc-hero, .bc-atl, .bc-art,
    .bc-dive, .bc-suno, .bc-concert,
    .bc-stat-concerts, .bc-stat-spotify,
    .bc-music, .bc-spotify, .bc-cta {
      grid-column: 1;
    }
  }
</style>
