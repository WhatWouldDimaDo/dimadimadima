---
import Layout from '../layouts/Layout.astro';

const TOPICS = [
  {
    title: 'Applied AI systems',
    body: 'From LLM evaluation and context layers to agent workflows people actually use.',
    icon: '<path d="M12 2a7 7 0 0 0-4 12.74V18h8v-3.26A7 7 0 0 0 12 2Z"/><path d="M9 22h6"/><path d="M9 18h6"/>',
  },
  {
    title: 'Data and analytics leadership',
    body: 'Org design, measurement strategy, and building teams that move business decisions.',
    icon: '<path d="M3 3v18h18"/><path d="m7 16 4-5 3 3 5-7"/>',
  },
  {
    title: 'Growth-stage operating problems',
    body: 'Turning ambiguity into a clear operating rhythm, useful systems, and visible outcomes.',
    icon: '<path d="M4 19 14 9"/><path d="M15 5h4v4"/><path d="M5 15v4h4"/><path d="m14 10 5-5"/>',
  },
  {
    title: 'Atlanta tech and side quests',
    body: 'Local founders, interesting events, and the useful or delightful things I build after bedtime.',
    icon: '<circle cx="12" cy="12" r="9"/><path d="m16 8-2 6-6 2 2-6 6-2Z"/>',
  },
];
---
<Layout title="Let's Talk" description="Get in touch with Dima Perkis — a Data & AI leader who builds revenue-producing systems from strategy through deployment.">
  <section class="contact-hero reveal">
    <div>
      <p class="page-eyebrow">Contact</p>
      <h1 class="page-title">Let’s build<br />something real.</h1>
      <p class="contact-lede">
        I’m exploring leadership roles where I can lead a team, stay close to the work,
        and turn new AI and data capabilities into systems that drive revenue and get used.
      </p>
    </div>
    <aside class="fit-note">
      <span class="section-kicker">Best fit</span>
      <p>Growth-stage SaaS or AI-native companies with a real team, a product or revenue mandate, and the appetite to move from pilots to production.</p>
      <div class="fit-tags" aria-label="Preferred work environment">
        <span>Player-coach scope</span><span>Private / growth stage</span><span>Atlanta hybrid</span>
      </div>
    </aside>
  </section>

  <section class="contact-methods reveal" aria-label="Contact methods">
    <a href="mailto:dperkis@gmail.com" class="contact-method">
      <span class="method-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
      </span>
      <span><strong>Email</strong><small>dperkis@gmail.com</small></span>
      <span class="method-arrow" aria-hidden="true">↗</span>
    </a>
    <a href="https://linkedin.com/in/dima-perkis" target="_blank" rel="noopener noreferrer" class="contact-method">
      <span class="method-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6Z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
      </span>
      <span><strong>LinkedIn</strong><small>linkedin.com/in/dima-perkis</small></span>
      <span class="method-arrow" aria-hidden="true">↗</span>
    </a>
  </section>

  <section class="talk-topics reveal">
    <span class="section-kicker">Conversation starters</span>
    <h2 class="section-title">Also happy to talk about</h2>
    <div class="topic-grid">
      {TOPICS.map(topic => (
        <article class="topic-card">
          <span class="topic-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" set:html={topic.icon} />
          </span>
          <div><h3>{topic.title}</h3><p>{topic.body}</p></div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .contact-hero { display:grid;grid-template-columns:minmax(0,1.35fr) minmax(260px,.65fr);gap:clamp(2rem,6vw,5rem);padding:clamp(4rem,8vw,7rem) 0 3.5rem;border-bottom:1px solid var(--border);align-items:end; }
  .contact-lede { max-width:43rem;margin:1.5rem 0 0;color:var(--muted);font-size:clamp(1rem,2vw,1.2rem);line-height:1.7; }
  .fit-note { padding:1.5rem;border:1px solid var(--border);border-radius:16px;background:color-mix(in srgb,var(--surface) 72%,transparent); }
  .fit-note p { margin:0;color:var(--ink);font-size:.95rem;line-height:1.65; }
  .fit-tags { display:flex;flex-wrap:wrap;gap:.45rem;margin-top:1.25rem; }
  .fit-tags span { border:1px solid var(--border);border-radius:999px;padding:.28rem .65rem;color:var(--muted);font-family:'DM Mono',monospace;font-size:.68rem;text-transform:uppercase;letter-spacing:.06em; }
  .contact-methods { display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin:2.5rem 0 5rem; }
  .contact-method { display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:1rem;padding:1.2rem 1.25rem;border:1px solid var(--border);border-radius:14px;color:var(--ink);text-decoration:none;background:var(--surface);transition:transform .2s,border-color .2s; }
  .contact-method:hover { transform:translateY(-2px);border-color:color-mix(in srgb,var(--gold) 45%,var(--border)); }
  .method-icon,.topic-icon { display:grid;place-items:center;width:2.7rem;height:2.7rem;border-radius:10px;background:color-mix(in srgb,var(--gold) 10%,var(--surface));color:var(--gold); }
  .method-icon svg,.topic-icon svg { width:1.25rem;height:1.25rem;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round; }
  .contact-method strong,.contact-method small { display:block; }
  .contact-method strong { font-size:.95rem;font-weight:600; }
  .contact-method small { margin-top:.1rem;color:var(--muted);font-size:.78rem;overflow-wrap:anywhere; }
  .method-arrow { color:var(--gold);font-size:1.15rem; }
  .talk-topics { margin-bottom:3rem; }
  .topic-grid { display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem; }
  .topic-card { display:flex;gap:1rem;align-items:flex-start;min-height:150px;padding:1.35rem;border:1px solid var(--border);border-radius:16px;background:transparent; }
  .topic-icon { flex:0 0 2.7rem;background:var(--surface); }
  .topic-card h3 { margin:.15rem 0 .45rem;color:var(--ink);font-size:1rem;font-weight:600;letter-spacing:-.015em; }
  .topic-card p { margin:0;color:var(--muted);font-size:.84rem;line-height:1.6; }
  @media (max-width:720px) { .contact-hero{grid-template-columns:1fr;padding-top:3rem}.contact-methods,.topic-grid{grid-template-columns:1fr}.contact-methods{margin-bottom:4rem}.page-title br{display:none} }
</style>
