---
import Layout from '../layouts/Layout.astro';
import ResumeExperience from '../components/ResumeExperience';

const EXPERTISE = [
  { title: 'Applied AI systems', body: 'Evaluation, context layers, and agent workflows designed around adoption—not demo theater.', icon: '<path d="M12 2a7 7 0 0 0-4 12.74V18h8v-3.26A7 7 0 0 0 12 2Z"/><path d="M9 22h6M9 18h6"/>' },
  { title: 'Analytics leadership', body: 'Building capable teams, useful operating rhythms, and measurement that changes decisions.', icon: '<path d="M3 3v18h18"/><path d="M18 17V9M13 17V5M8 17v-3"/>' },
  { title: 'Revenue & GTM strategy', body: 'Pricing, retention, growth, and sales systems grounded in customer behavior and economics.', icon: '<path d="m3 17 6-6 4 4 8-9"/><path d="M15 6h6v6"/>' },
  { title: 'Zero-to-one operating', body: 'Turning ambiguous mandates into a first working system, a clear story, and a team that can scale it.', icon: '<path d="M4 19h16"/><path d="m6 15 5-5 3 3 4-6"/><circle cx="6" cy="15" r="1"/>' },
  { title: 'Executive translation', body: 'Moving fluently between boards, founders, technical teams, and the people doing the daily work.', icon: '<path d="M21 15a4 4 0 0 1-4 4H8l-5 3v-7a4 4 0 0 1-2-3.5V7a4 4 0 0 1 4-4h12a4 4 0 0 1 4 4v8Z"/>' },
  { title: 'Hands-on systems building', body: 'Python, SQL, TypeScript, and modern AI tools—enough depth to prototype, inspect, and unblock.', icon: '<path d="m16 18 6-6-6-6M8 6l-6 6 6 6M14 4l-4 16"/>' },
];

const CLIENTS = [
  { name: 'Mailchimp', logo: '/images/logos/mailchimp.svg' },
  { name: 'Lahzo', logo: '/images/logos/clients/lahzo.png', color: true },
  { name: 'Equifax', logo: '/images/logos/equifax.svg' },
  { name: 'Walmart', logo: '/images/logos/clients/walmart.svg', color: true },
  { name: 'Target', logo: '/images/logos/clients/target.svg', color: true },
  { name: 'Blue Cross Blue Shield NC', logo: '/images/logos/clients/bcbs-nc.svg', color: true },
  { name: 'Verizon', logo: '/images/logos/clients/verizon.svg', color: true },
  { name: 'AT&T', logo: '/images/logos/clients/att.svg', color: true },
  { name: 'New York Life', logo: '/images/logos/clients/new-york-life.svg' },
  { name: 'CDC', logo: '/images/logos/clients/cdc.svg', color: true },
  { name: 'American Cancer Society', logo: '/images/logos/clients/american-cancer-society.svg', color: true },
  { name: 'Apollo', logo: '/images/logos/clients/apollo.svg' },
  { name: 'Pfizer', logo: '/images/logos/clients/pfizer.svg', color: true },
  { name: 'Shiseido', logo: '/images/logos/clients/shiseido.svg' },
  { name: 'Laura Mercier', logo: '/images/logos/clients/laura-mercier.svg' },
  { name: 'Oldcastle Materials', logo: '/images/logos/clients/oldcastle.svg' },
];

const TOOLS = [
  { logo: '/images/logos/tools/openai.svg', label: 'OpenAI' },
  { logo: '/images/logos/tools/claude.svg', label: 'Claude' },
  { logo: '/images/logos/tools/googlegemini.svg', label: 'Gemini' },
  { logo: '/images/logos/tools/github.svg', label: 'GitHub' },
  { logo: '/images/logos/tools/vercel.svg', label: 'Vercel' },
  { logo: '/images/logos/tools/replit.svg', label: 'Replit' },
];
---
<Layout title="Professional Experience" description="Dima Perkis — Data & AI leader who turns emerging capabilities into revenue-producing systems.">
  <section class="resume-hero reveal">
    <div>
      <p class="page-eyebrow">Professional experience</p>
      <h1 class="page-title">Ideas into<br />working systems.</h1>
      <p class="resume-lede">I lead teams that turn messy data and emerging AI capabilities into systems that expand what teams can do, improve decisions, and drive revenue—from board-level strategy through production.</p>
      <div class="resume-actions">
        <span>VP, Data & AI · Atlanta</span>
        <a href="https://linkedin.com/in/dima-perkis" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
      </div>
    </div>
    <img src="/images/dima.jpeg" alt="Dima Perkis" class="resume-headshot" />
  </section>

  <section class="expertise-section reveal">
    <span class="section-kicker">What I do best</span>
    <h2 class="section-title">Core expertise</h2>
    <div class="expertise-grid">
      {EXPERTISE.map(item => (
        <article class="expertise-card" tabindex="0">
          <span class="expertise-icon" aria-hidden="true"><svg viewBox="0 0 24 24" set:html={item.icon} /></span>
          <div><h3>{item.title}</h3><p>{item.body}</p></div>
          <span class="expertise-arrow" aria-hidden="true">↗</span>
        </article>
      ))}
    </div>
  </section>

  <section class="tools-section reveal">
    <div><span class="section-kicker">Tools</span><h2 class="section-title">Close enough to the work</h2><p>I use these to prototype, inspect, and unblock—not as a substitute for the engineering and data teams I lead.</p></div>
    <div class="tool-row">{TOOLS.map(tool => <div class="tool"><img src={tool.logo} alt="" /><span>{tool.label}</span></div>)}</div>
  </section>

  <section class="experience-section reveal">
    <span class="section-kicker">Career</span>
    <h2 class="section-title">Experience</h2>
    <ResumeExperience client:load />
  </section>

  <section class="clients-section reveal" aria-labelledby="clients-title">
    <span class="section-kicker">Across the work</span>
    <h2 class="section-title" id="clients-title">Selected companies and clients</h2>
    <div class="logo-marquee">
      <div class="logo-track">
        {[...CLIENTS, ...CLIENTS].map((client, index) => (
          <div class="client-logo" aria-hidden={index >= CLIENTS.length ? 'true' : undefined}>
            <img src={client.logo} alt={index < CLIENTS.length ? client.name : ''} class:list={{'logo-color':client.color}} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="education-section reveal">
    <span class="section-kicker">Education</span><h2 class="section-title">The formal part</h2>
    <div class="education-grid">
      <article><img src="/images/logos/fuqua.svg" alt="Duke Fuqua" /><div><h3>MBA · Duke University</h3><p>Fuqua School of Business · Strategy & Finance · 2017</p></div></article>
      <article><img src="/images/logos/emory.svg" alt="Emory University" /><div><h3>BBA · Emory University</h3><p>Goizueta Business School · Marketing & Russian · 2009</p></div></article>
    </div>
  </section>
</Layout>

<style>
  .resume-hero{display:grid;grid-template-columns:minmax(0,1fr) 240px;gap:clamp(2rem,7vw,6rem);padding:clamp(4rem,8vw,7rem) 0 4rem;border-bottom:1px solid var(--border);align-items:end}.resume-lede{max-width:46rem;margin:1.5rem 0 0;color:var(--muted);font-size:clamp(1rem,2vw,1.18rem);line-height:1.75}.resume-actions{display:flex;align-items:center;gap:1rem;margin-top:1.5rem;color:var(--muted);font-family:'DM Mono',monospace;font-size:.72rem;text-transform:uppercase;letter-spacing:.08em}.resume-actions a{color:var(--gold);text-decoration:none}.resume-headshot{width:100%;aspect-ratio:1/1.15;object-fit:cover;border-radius:22px;border:1px solid var(--border)}
  .expertise-section,.experience-section,.clients-section,.education-section{margin:5.5rem 0}.expertise-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}.expertise-card{position:relative;display:grid;grid-template-columns:auto 1fr auto;gap:1rem;align-items:start;min-height:158px;padding:1.4rem;border:1px solid var(--border);border-radius:18px;outline:none;transition:background .2s,border-color .2s,transform .2s}.expertise-card:hover,.expertise-card:focus-visible{transform:translateY(-2px);border-color:color-mix(in srgb,var(--gold) 45%,var(--border));background:var(--surface)}.expertise-icon{display:grid;place-items:center;width:2.9rem;height:2.9rem;border-radius:12px;background:var(--ink);color:var(--bg)}.expertise-icon svg{width:1.35rem;height:1.35rem;fill:none;stroke:currentColor;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}.expertise-card h3{margin:.25rem 0 .55rem;font-size:1.05rem;font-weight:600;letter-spacing:-.025em}.expertise-card p{margin:0;color:var(--muted);font-size:.82rem;line-height:1.55;opacity:.18;transform:translateY(5px);transition:opacity .2s,transform .2s}.expertise-card:hover p,.expertise-card:focus-visible p{opacity:1;transform:none}.expertise-arrow{color:var(--gold);opacity:.35}
  .tools-section{display:grid;grid-template-columns:minmax(250px,.8fr) minmax(0,1.2fr);gap:3rem;align-items:center;margin:5.5rem 0;padding:2rem;border:1px solid var(--border);border-radius:20px}.tools-section .section-title{margin-bottom:.75rem}.tools-section p{margin:0;color:var(--muted);font-size:.85rem;line-height:1.65}.tool-row{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem}.tool{display:flex;align-items:center;gap:.65rem;padding:.85rem;border-radius:12px;background:var(--surface);font-size:.78rem}.tool img{width:20px;height:20px;object-fit:contain;filter:var(--logo-filter)}
  .logo-marquee{overflow:hidden;mask-image:linear-gradient(to right,transparent,#000 8%,#000 92%,transparent);padding:1.5rem 0}.logo-track{display:flex;width:max-content;align-items:center;animation:logo-scroll 36s linear infinite}.client-logo{display:grid;place-items:center;width:160px;height:74px;padding:1rem}.client-logo img{max-width:118px;max-height:40px;object-fit:contain;opacity:.72;filter:grayscale(1);transition:filter .2s,opacity .2s}.client-logo:hover img{opacity:1;filter:none}html[data-theme="dark"] .client-logo img:not(.logo-color),html[data-theme="hacker"] .client-logo img:not(.logo-color){filter:brightness(0) invert(.85)}@keyframes logo-scroll{to{transform:translateX(-50%)}}.logo-marquee:hover .logo-track{animation-play-state:paused}
  .education-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.education-grid article{display:flex;align-items:center;gap:1.25rem;padding:1.5rem;border:1px solid var(--border);border-radius:16px}.education-grid img{width:88px;max-height:42px;object-fit:contain}.education-grid h3{margin:0;font-size:1rem;font-weight:600;letter-spacing:-.02em}.education-grid p{margin:.3rem 0 0;color:var(--muted);font-size:.75rem;line-height:1.5}html[data-theme="dark"] .education-grid img,html[data-theme="hacker"] .education-grid img{filter:brightness(0) invert(.85)}
  @media (hover:none){.expertise-card p{opacity:1;transform:none}}
  @media (prefers-reduced-motion:reduce){.logo-track{animation:none;flex-wrap:wrap;width:100%;justify-content:center}.logo-track .client-logo:nth-child(n+17){display:none}}
  @media(max-width:760px){.resume-hero{grid-template-columns:1fr}.resume-headshot{width:min(100%,360px)}.expertise-grid,.education-grid,.tools-section{grid-template-columns:1fr}.tool-row{grid-template-columns:repeat(2,1fr)}.expertise-card p{opacity:1;transform:none}.logo-track{animation-duration:28s}}
  @media(max-width:480px){.resume-actions{align-items:flex-start;flex-direction:column}.expertise-grid{grid-template-columns:1fr}.expertise-card{grid-template-columns:auto 1fr}.expertise-arrow{display:none}}
</style>
