---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const aiIdeas = allProjects.find(p => p.slug === 'ai-ideas-explorer');

const songs = (await getCollection('posts'))
  .filter(p => !p.data.draft && p.data.type === 'song' && p.data.youtube)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const song = songs[0];

function ytId(url: string) {
  const m = url?.match(/(?:youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/watch\?v=)([^&?/\s]+)/);
  return m ? m[1] : null;
}
const songVid = song?.data.youtube ? ytId(song.data.youtube) : null;
const songThumb = songVid ? `https://img.youtube.com/vi/${songVid}/hqdefault.jpg` : null;
// NOTE: inline <iframe> player is ready to swap in, but Dima's YouTube channel has
// "Allow embedding" turned OFF (all videos 401 on oEmbed). Enable it in YouTube
// Studio, then replace the thumbnail link below with the iframe version.
---

<Layout title="Dima Perkis" description="VP, Data & AI. I build AI strategies at the enterprise level and deploy the systems that make them real. Atlanta, GA." defaultTheme="light" heroNav={true}>

  <div class="bento">

    <!-- ── INTRO BANNER (full width) ─────────────── -->
    <div class="bc bc-intro">
      <nav class="bc-top-links" aria-label="Primary">
        <a href="/resume">Professional Experience</a>
        <span class="bc-top-sep" aria-hidden="true"></span>
        <a href="/projects">AI Side Quests</a>
        <span class="bc-top-sep" aria-hidden="true"></span>
        <a href="/about">About Me</a>
        <span class="bc-top-sep" aria-hidden="true"></span>
        <a href="/contact">Contact</a>
      </nav>
      <div class="bc-intro-main">
        <div class="bc-intro-left">
          <img src="/images/brand/dima-dima-dima/png/dima-mark-concept-01-192.png" alt="" class="bc-mark" />
          <h1 class="bc-name">Dima Perkis</h1>
        </div>
        <div class="bc-intro-right">
          <p class="bc-bio">
            Data &amp; AI leader. I lead teams that turn emerging capabilities into
            revenue-producing systems — from board-level strategy through production.
          </p>
          <div class="bc-tags">
            <span class="bc-tag bc-tag--gold">AI strategy</span>
            <span class="bc-tag bc-tag--violet">Deployed systems</span>
            <span class="bc-tag bc-tag--muted">Atlanta, GA</span>
          </div>
        </div>
      </div>
      <div class="bc-proof" aria-label="Selected career outcomes">
        <div><strong>$120M+</strong><span>Revenue impact</span></div>
        <div><strong>6×</strong><span>Team growth</span></div>
        <div><strong>$200K</strong><span>Capacity redeployed with AI</span></div>
      </div>
    </div>

    <!-- ── ON DIMA'S RADAR: Happening in Atlanta ──── -->
    <a href="/atl" class="bc bc-live">
      <div class="bc-live-brand">
        <span class="bc-radar-ping"><img src="/atl/favicon.svg" alt="" /></span>
        <span class="bc-live-brandname">On Dima's Radar</span>
      </div>
      <div class="bc-live-title">Happening in Atlanta</div>
      <div id="atl-live-list" class="bc-live-list">
        <div class="bc-live-empty">Loading the radar…</div>
      </div>
      <div class="bc-live-foot">
        Straight from my event-intelligence pipeline · Full radar →
      </div>
    </a>

    <!-- ── Dewey ──────────────────────────────────── -->
    <a href="/projects/dewey" class="bc bc-project bc-dewey">
      <img src="/images/dewey/dewey-check-list.png" alt="Dewey — live library shelf check" class="bc-img" />
      <div class="bc-project-body">
        <div class="bc-status bc-status--gold">Active</div>
        <div class="bc-project-title">Dewey</div>
        <div class="bc-project-desc">Book recs for the whole family, checked live against the library shelf</div>
        <span class="bc-project-view">View project →</span>
      </div>
    </a>

    <!-- ── SUNO ───────────────────────────────────── -->
    <div class="bc bc-suno-cell">
      <div class="bc-suno-head">
        <span class="bc-music-eyebrow">♫ Suno Factory</span>
        <span class="bc-suno-name">{song?.data.title ?? 'AI songs for my kids'}</span>
      </div>
      <a
        href={song?.data.youtube ?? '/projects'}
        target="_blank"
        rel="noopener noreferrer"
        class="bc-suno-play"
      >
        {songThumb && (
          <img src={songThumb} alt={song?.data.title} class="bc-img bc-img--dim" />
        )}
        <span class="bc-play">▶</span>
      </a>
    </div>

    <!-- ── ToddlerMaps ────────────────────────────── -->
    <a href="/projects/toddlermaps" class="bc bc-project bc-tmaps">
      <img src="/images/toddlermaps/toddlermaps-overview-map.png" alt="ToddlerMaps" class="bc-img" />
      <div class="bc-project-body">
        <div class="bc-status bc-status--gold">Live</div>
        <div class="bc-project-title">ToddlerMaps</div>
        <div class="bc-project-desc">Maps of a toddler's world · AI stickers</div>
        <span class="bc-project-view">View project →</span>
      </div>
    </a>

    <!-- ── AI Ideas Explorer ──────────────────────── -->
    <a href="/projects/ai-ideas-explorer" class="bc bc-project bc-ideas" id="bc-ideas-cell">
      {aiIdeas?.data.image && (
        <img src={aiIdeas.data.image} alt="AI Ideas Explorer" class="bc-img" />
      )}
      <span class="bc-live-badge bc-ideas-live"><span class="dot-pulse"></span>Live</span>
      <div class="bc-project-body">
        <div class="bc-status bc-status--gold">Live</div>
        <div class="bc-project-title">AI Ideas Explorer</div>
        <div class="bc-project-desc">1,160 AI business ideas, scored</div>
        <span class="bc-project-view">View project →</span>
      </div>
    </a>

    <!-- ── Georgia Power Analysis ─────────────────── -->
    <a href="/projects/power-analysis" class="bc bc-project bc-power">
      <img src="/images/power-dashboard.png" alt="Georgia Power Analysis" class="bc-img" />
      <div class="bc-project-body">
        <div class="bc-status bc-status--gold">Active</div>
        <div class="bc-project-title">Georgia Power Analysis</div>
        <div class="bc-project-desc">13 months of bills + 10,487 hourly readings, decoded</div>
        <span class="bc-project-view">View project →</span>
      </div>
    </a>

    <!-- ── Music Data ──────────────────────────────── -->
    <a href="/projects/spotify-analysis" class="bc bc-project bc-music">
      <img src="/images/spotify-hero.png" alt="Music Data" class="bc-img" />
      <div class="bc-project-body">
        <div class="bc-status bc-status--gold">Active</div>
        <div class="bc-project-title">Music Data</div>
        <div class="bc-project-desc">147,594 streams · 178 shows · 18 years of listening data</div>
        <span class="bc-project-view">View project →</span>
      </div>
    </a>

    <!-- ── All Roads to Kill Bill ──────────────────── -->
    <a href="/projects/kill-bill" class="bc bc-project bc-killbill">
      <img src="/images/kill-bill.jpg" alt="All Roads to Kill Bill" class="bc-img" />
      <div class="bc-project-body">
        <div class="bc-project-title">All Roads to Kill Bill</div>
        <div class="bc-project-desc">Every Tarantino connection, mapped</div>
        <span class="bc-project-view">View project →</span>
      </div>
    </a>

  </div>

  <!-- Live ATL feed: lazy-load the radar data layer after paint -->
  <script is:inline>
    (function () {
      function renderRadar() {
        try {
          var list = document.getElementById('atl-live-list');
          if (!list || typeof EVENTS === 'undefined') return;
          var today = new Date(); today.setHours(0, 0, 0, 0);
          var upcoming = EVENTS
            .filter(function (e) { return new Date(e.dateEnd || e.date) >= today; })
            .sort(function (a, b) { return (b.score || 0) - (a.score || 0); })
            .slice(0, 14)
            .sort(function (a, b) { return new Date(a.date) - new Date(b.date); })
            .slice(0, 3);
          if (!upcoming.length) return;
          list.innerHTML = upcoming.map(function (e) {
            var isAbsolute = e.imageUrl && /^https?:\/\//i.test(e.imageUrl);
            var imgSrc = e.imageUrl ? (isAbsolute ? e.imageUrl : '/atl/' + e.imageUrl) : null;
            var thumb = imgSrc
              ? '<img class="bc-live-thumb" src="' + imgSrc + '" alt="" loading="lazy" '
                + 'onerror="this.outerHTML=\'<span class=&quot;bc-live-thumb bc-live-thumb--emoji&quot;>' + (e.emoji || '📅') + '</span>\'">'
              : '<span class="bc-live-thumb bc-live-thumb--emoji">' + (e.emoji || '📅') + '</span>';
            return '<div class="bc-live-row">'
              + thumb
              + '<span class="bc-live-event"><span class="bc-live-name">' + e.title + '</span>'
              + '<span class="bc-live-venue">' + e.dateStr + ' · ' + (e.venue || '') + '</span></span>'
              + '<span class="bc-live-kind">' + (e.emoji || '') + '</span>'
              + '</div>';
          }).join('');
        } catch (err) { /* leave fallback text */ }
      }
      function loadRadar() {
        var s = document.createElement('script');
        s.src = '/atl/data.js';
        s.onload = renderRadar;
        document.body.appendChild(s);
      }
      if ('requestIdleCallback' in window) requestIdleCallback(loadRadar);
      else setTimeout(loadRadar, 250);
    })();
  </script>

  <script is:inline>
    (function () {
      var cell = document.getElementById('bc-ideas-cell');
      if (!cell || !('IntersectionObserver' in window)) return;
      var io = new IntersectionObserver(function (entries) {
        if (!entries.some(function (e) { return e.isIntersecting; })) return;
        io.disconnect();
        var frame = document.createElement('iframe');
        frame.src = 'https://ai-ideas-explorer.vercel.app';
        frame.loading = 'lazy';
        frame.title = 'AI Ideas Explorer';
        frame.className = 'bc-ideas-frame';
        frame.addEventListener('load', function () {
          cell.classList.add('bc-ideas--live');
        });
        cell.insertBefore(frame, cell.firstChild);
      }, { rootMargin: '200px' });
      io.observe(cell);
    })();
  </script>

</Layout>

<style>
  /* ─── Grid ──────────────────────────────────────── */
  .bento {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: auto repeat(3, 280px);
    gap: 1rem;
    padding-top: 1.75rem;
    padding-bottom: 4rem;
  }

  /* ─── Base cell ─────────────────────────────────── */
  .bc {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    transition: border-color 0.2s ease, transform 0.25s ease, box-shadow 0.25s ease;
    animation: bc-rise 0.65s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .bento .bc:nth-child(1) { animation-delay: 0.05s; }
  .bento .bc:nth-child(2) { animation-delay: 0.12s; }
  .bento .bc:nth-child(3) { animation-delay: 0.19s; }
  .bento .bc:nth-child(4) { animation-delay: 0.26s; }
  .bento .bc:nth-child(5) { animation-delay: 0.33s; }
  .bento .bc:nth-child(6) { animation-delay: 0.40s; }
  .bento .bc:nth-child(7) { animation-delay: 0.47s; }
  .bento .bc:nth-child(8) { animation-delay: 0.54s; }
  .bento .bc:nth-child(9) { animation-delay: 0.61s; }
  @keyframes bc-rise {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .bc { animation: none; }
  }
  a.bc {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }
  a.bc:hover {
    border-color: color-mix(in srgb, var(--gold) 45%, var(--border));
    transform: translateY(-3px);
    box-shadow: 0 10px 30px -12px color-mix(in srgb, var(--ink) 25%, transparent);
  }

  /* ─── Grid placement ────────────────────────────── */
  .bc-intro     { grid-column: 1 / 7; grid-row: 1; }
  .bc-live      { grid-column: 1 / 4; grid-row: 2; }
  .bc-dewey     { grid-column: 4 / 7; grid-row: 2; }
  .bc-suno-cell { grid-column: 1 / 3; grid-row: 3; }
  .bc-tmaps     { grid-column: 3 / 5; grid-row: 3; }
  .bc-ideas     { grid-column: 5 / 7; grid-row: 3; }
  .bc-power     { grid-column: 1 / 3; grid-row: 4; }
  .bc-music     { grid-column: 3 / 5; grid-row: 4; }
  .bc-killbill  { grid-column: 5 / 7; grid-row: 4; }

  /* ─── Shared image pattern ──────────────────────── */
  .bc-img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }
  a.bc:hover .bc-img { transform: scale(1.04); }
  .bc-tmaps .bc-img { object-position: center; }
  .bc-dewey .bc-img { object-position: top left; }

  /* ─── INTRO BANNER ──────────────────────────────── */
  .bc-intro {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    padding: 1.5rem 2.25rem 1.75rem;
  }
  /* Horizontal top links — same grammar as the sticky nav they morph into */
  .bc-top-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-bottom: 1.1rem;
    border-bottom: 1px solid var(--border);
  }
  .bc-top-links a {
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .bc-top-links a:hover { color: var(--ink); }
  .bc-top-sep { width: 1px; height: 12px; background: var(--border-hi); display: inline-block; }
  .bc-intro-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .bc-intro-left {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }
  .bc-mark {
    height: 96px;
    width: auto;
    display: block;
    flex-shrink: 0;
  }
  .bc-name {
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    line-height: 1.0;
    letter-spacing: -0.055em;
    color: var(--ink);
    margin: 0;
    white-space: nowrap;
  }
  .bc-intro-right {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-width: 30rem;
    min-width: min(100%, 280px);
  }
  .bc-bio {
    font-size: 0.98rem;
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }
  .bc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .bc-tag {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.2em 0.65em;
    border: 1px solid var(--border);
    font-family: 'DM Mono', monospace;
  }
  .bc-tag--gold   { color: var(--gold);   border-color: color-mix(in srgb, var(--gold) 30%, transparent); }
  .bc-tag--violet { color: var(--violet); border-color: color-mix(in srgb, var(--violet) 30%, transparent); }
  .bc-tag--muted  { color: var(--muted); }
  .bc-proof { display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--border);padding-top:1.25rem; }
  .bc-proof>div { display:flex;align-items:baseline;gap:.65rem;padding:0 1.25rem;border-right:1px solid var(--border); }
  .bc-proof>div:first-child { padding-left:0; }
  .bc-proof>div:last-child { border-right:0; }
  .bc-proof strong { color:var(--ink);font-size:1.35rem;letter-spacing:-.04em; }
  .bc-proof span { color:var(--muted);font-family:'DM Mono',monospace;font-size:.65rem;text-transform:uppercase;letter-spacing:.07em; }

  /* ─── LIVE ATL ──────────────────────────────────── */
  .bc-live {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.5rem;
  }
  .bc-live-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }
  .bc-radar-ping {
    position: relative;
    display: inline-flex;
    width: 26px; height: 26px;
    flex-shrink: 0;
  }
  .bc-radar-ping img { width: 100%; height: 100%; display: block; }
  .bc-radar-ping::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid #C2410C;
    opacity: 0;
    animation: radar-ping 2.6s ease-out infinite;
  }
  @keyframes radar-ping {
    0%   { transform: scale(0.6); opacity: 0.7; }
    70%  { transform: scale(1.35); opacity: 0; }
    100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) { .bc-radar-ping::after { animation: none; } }
  .bc-live-brandname {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #C2410C;
  }
  .bc-live-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 1.45rem;
    color: var(--ink);
    margin-bottom: 0.6rem;
  }
  .bc-live :global(.bc-live-kind) {
    margin-left: auto;
    flex-shrink: 0;
    font-size: 1.05rem;
    opacity: 0.85;
  }
  .dot-pulse {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #5a9a6e;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .bc-live-badge {
    font-size: 0.75rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #5a9a6e;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .bc-live-list {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.1rem;
    min-height: 0;
  }
  .bc-live-empty {
    font-size: 0.75rem;
    font-family: 'DM Mono', monospace;
    color: var(--muted);
    opacity: 0.6;
  }
  .bc-live :global(.bc-live-row) {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--border);
  }
  .bc-live :global(.bc-live-row:last-child) { border-bottom: none; }
  .bc-live :global(.bc-live-thumb) {
    width: 44px; height: 44px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--border);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    background: color-mix(in srgb, var(--gold) 6%, transparent);
  }
  .bc-live :global(.bc-live-event) {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .bc-live :global(.bc-live-name) {
    font-size: 0.84rem;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bc-live :global(.bc-live-venue) {
    font-size: 0.75rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bc-live-foot {
    font-size: 0.75rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    opacity: 0.55;
    margin-top: 0.75rem;
    transition: opacity 0.15s, color 0.15s;
  }
  a.bc-live:hover .bc-live-foot { opacity: 1; color: var(--gold); }

  /* ─── SUNO ──────────────────────────────────────── */
  .bc-suno-cell {
    display: flex;
    flex-direction: column;
  }
  .bc-suno-head {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    padding: 0.8rem 1.1rem;
    border-bottom: 1px solid var(--border);
    min-width: 0;
  }
  .bc-music-eyebrow {
    font-size: 0.75rem;
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gold);
    flex-shrink: 0;
  }
  .bc-suno-name {
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bc-suno-play {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    min-height: 0;
  }
  .bc-suno-play .bc-img { position: absolute; inset: 0; }
  .bc-img--dim { filter: brightness(0.55); }
  .bc-suno-play:hover .bc-img--dim { filter: brightness(0.7); }
  .bc-play {
    position: relative;
    z-index: 1;
    width: 50px; height: 50px;
    border-radius: 50%;
    background: rgba(212,168,83,0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000;
    font-size: 0.95rem;
    padding-left: 4px;
    transition: background 0.2s, transform 0.2s;
  }
  .bc-suno-play:hover .bc-play { background: var(--gold); transform: scale(1.1); }

  /* ─── PROJECT CARDS ─────────────────────────────── */
  .bc-project-body {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(12,12,14,0.97) 55%, transparent 100%);
    padding: 0.85rem 1.1rem;
    z-index: 3;
  }

  /* ─── AI IDEAS LIVE EMBED ───────────────────────── */
  .bc-ideas :global(.bc-ideas-frame) {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    border: 0;
    display: block;
    pointer-events: none;
    background: #0c0c0e;
    opacity: 0;
    transition: opacity 0.6s ease;
