---
interface Props {
  title:       string;
  description: string;
  tags:        string[];
  url?:        string;
  github?:     string;
  image?:      string;
  status?:     string;
  date?:       Date;
  slug?:       string;
  style?:      string;
}
const { title, description, tags, url, github, image, status, date, slug, style = '' } = Astro.props;
const href = slug ? `/projects/${slug}` : (url || github || '#');
const hasLink = !!(slug || url || github);
const isExternal = !slug && !!(url || github);

const STATUS_CONFIG: Record<string, { label: string; color: string }> = {
  live:       { label: 'Live',       color: '#5a9a6e' },
  active:     { label: 'Active',     color: '#d4a853' },
  built:      { label: 'Built',      color: '#7c6fcd' },
  concept:    { label: 'Concept',    color: '#6b6a72' },
  research:   { label: 'Research',   color: '#6b8fad' },
  experiment: { label: 'Experiment', color: '#c07050' },
};
const statusMeta = status ? (STATUS_CONFIG[status] ?? { label: status, color: '#6b6a72' }) : null;
---
<a
  class={`card-hover flex flex-col bg-surface text-inherit no-underline group overflow-hidden border border-border ${style}`}
  href={hasLink ? href : undefined}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener' : undefined}
  style={!hasLink ? 'cursor:default;pointer-events:none;' : ''}
>
  {image ? (
    <div class="w-full overflow-hidden" style="aspect-ratio:3/2;flex-shrink:0;">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        loading="lazy"
      />
    </div>
  ) : (
    <div class="flex-1 flex flex-col justify-center px-5 py-6" style="min-height:8rem;background:linear-gradient(135deg,var(--surface) 60%,rgba(212,168,83,.06));">
      <h2 class="font-serif text-[1.25rem] font-normal leading-snug text-ink group-hover:text-gold transition-colors duration-200 mb-2">
        {title}
      </h2>
      {statusMeta && (
        <span style={`font-size:.6rem;font-family:'DM Mono',monospace;text-transform:uppercase;letter-spacing:.12em;color:${statusMeta.color};display:flex;align-items:center;gap:.3rem;`}>
          <span style={`width:4px;height:4px;border-radius:50%;background:${statusMeta.color};`}></span>
          {statusMeta.label}
        </span>
      )}
    </div>
  )}

  {image && (
    <div class="flex items-center gap-2 px-3 border-t border-border" style="min-height:2.625rem;flex-shrink:0;">
      {statusMeta && (
        <span style={`width:5px;height:5px;border-radius:50%;background:${statusMeta.color};flex-shrink:0;`}></span>
      )}
      <h2 class="font-serif text-[0.9rem] font-normal leading-tight text-ink group-hover:text-gold transition-colors duration-200 truncate flex-1">
        {title}
      </h2>
      {isExternal && (
        <span class="text-muted text-xs flex-shrink-0 group-hover:text-gold transition-colors">↗</span>
      )}
    </div>
  )}
</a>
