---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About" description="Dima Perkis — VP Strategy & Analytics, systems builder, ADHD brain, father of Dean & Ruby.">

  <!-- Hero -->
  <section style="padding-top:4rem;padding-bottom:3rem;border-bottom:1px solid var(--border);">
    <div style="display:flex;align-items:flex-start;gap:3rem;flex-wrap:wrap;">
      <div style="flex:1;min-width:min(100%,320px);">
        <p style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--gold);margin:0 0 1rem;">About</p>
        <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2.5rem,7vw,4.5rem);line-height:1.05;letter-spacing:-.02em;color:var(--ink);margin:0 0 1.5rem;">
          I help companies<br/>understand AI.<br/>
          <span style="color:var(--muted);">I use AI to understand<br/>everything else.</span>
        </h1>
        <p style="font-size:.9rem;color:var(--muted);line-height:1.75;max-width:36rem;margin:0;">
          VP of Strategy & Analytics at Lahzo. Before that: Equifax, Mailchimp, Accenture, A&M, PwC, Booz Allen.
          Fifteen years of turning data into decisions. Also: father of Dean & Ruby, Everesting finisher, improv comedian,
          and compulsive builder of things that probably shouldn't exist.
        </p>
      </div>
      <div style="flex-shrink:0;">
        <img src="/images/dima.jpeg" alt="Dima Perkis"
          style="width:160px;height:160px;border-radius:50%;object-fit:cover;border:2px solid var(--border);" />
      </div>
    </div>
  </section>

  <!-- Dual audience strip -->
  <section style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,320px),1fr));gap:1px;background:var(--border);border:1px solid var(--border);margin-top:2.5rem;margin-bottom:3rem;">
    <div style="background:var(--surface);padding:2rem;">
      <p style="font-size:.6rem;text-transform:uppercase;letter-spacing:.15em;color:var(--gold);margin:0 0 .75rem;">For Companies</p>
      <p style="font-family:'DM Serif Display',serif;font-size:1.15rem;color:var(--ink);line-height:1.4;margin:0 0 .75rem;">Analytics leadership + AI strategy</p>
      <p style="font-size:.8rem;color:var(--muted);line-height:1.65;margin:0;">
        15+ years scaling analytics orgs, building AI systems, and leading cross-functional teams.
        $400M+ in documented business impact. I sit between the data and the C-suite and make both sides smarter.
      </p>
    </div>
    <div style="background:var(--surface);padding:2rem;">
      <p style="font-size:.6rem;text-transform:uppercase;letter-spacing:.15em;color:var(--violet);margin:0 0 .75rem;">For AI Builders</p>
      <p style="font-family:'DM Serif Display',serif;font-size:1.15rem;color:var(--ink);line-height:1.4;margin:0 0 .75rem;">AI tools, systems, and creative experiments</p>
      <p style="font-size:.8rem;color:var(--muted);line-height:1.65;margin:0;">
        I build my own AI infrastructure — multi-agent clusters, automation pipelines, ML systems, voice tools.
        The projects section is the lab. Everything here actually runs.
      </p>
    </div>
  </section>

  <!-- ADHD profile -->
  <section style="margin-bottom:3rem;">
    <h2 style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin-bottom:1.25rem;">ADHD as Operating System</h2>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1px;border:1px solid var(--border);background:var(--border);">
      <div style="background:var(--surface);padding:1.75rem;">
        <p style="font-size:.65rem;text-transform:uppercase;letter-spacing:.12em;color:var(--gold);margin:0 0 .75rem;">The upsides</p>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.5rem;">
          {[
            'Pattern recognition across domains',
            'Hyperfocus on problems I care about',
            'Creative leaps and novel connections',
            'High output when aligned with purpose',
            'Energizing presence in teams',
          ].map(s => (
            <li style="font-size:.8rem;color:var(--muted);line-height:1.5;display:flex;gap:.6rem;">
              <span style="color:var(--gold);flex-shrink:0;">+</span>{s}
            </li>
          ))}
        </ul>
      </div>
      <div style="background:var(--surface);padding:1.75rem;">
        <p style="font-size:.65rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin:0 0 .75rem;">What I've built around it</p>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.5rem;">
          {[
            'Morning planning — Top 3 priorities only',
            'AI-assisted calendaring and task capture',
            'Afternoon energy check-ins via HowYaDoin',
            'External accountability structures',
            'Systems that run when my brain won\'t',
          ].map(s => (
            <li style="font-size:.8rem;color:var(--muted);line-height:1.5;display:flex;gap:.6rem;">
              <span style="color:var(--muted);flex-shrink:0;">→</span>{s}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Core values -->
  <section style="margin-bottom:3rem;">
    <h2 style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin-bottom:1.25rem;">Core Values</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,300px),1fr));gap:1px;border:1px solid var(--border);background:var(--border);">
      {[
        { v: 'Family & Security',       desc: 'As an immigrant and provider — peace of mind through intentional living.' },
        { v: 'Joy, Awe & Adventure',    desc: 'Most alive when laughing, exploring, or hearing a song that breaks something open.' },
        { v: 'Growth & Curiosity',      desc: 'From philosophy to AI to woodworking. Learning keeps me engaged.' },
        { v: 'Physical Vitality',       desc: 'Want to hike mountains with Dean & Ruby in 30 years. Movement is medicine.' },
        { v: 'Resilience',              desc: 'My identity is forged in challenge. I believe in falling forward.' },
        { v: 'Contribution',            desc: 'Leave things better than I found them — lifting others, connecting people to meaning.' },
      ].map(cv => (
        <div style="background:var(--surface);padding:1.25rem 1.5rem;">
          <p style="font-family:'DM Serif Display',serif;font-size:.95rem;color:var(--ink);margin:0 0 .35rem;">{cv.v}</p>
          <p style="font-size:.775rem;color:var(--muted);line-height:1.55;margin:0;">{cv.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Current season + bucket list sample -->
  <section style="margin-bottom:3rem;display:grid;grid-template-columns:1fr 1fr;gap:1px;border:1px solid var(--border);background:var(--border);">
    <div style="background:var(--surface);padding:2rem;">
      <p style="font-size:.6rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin:0 0 .75rem;">Current Season</p>
      <p style="font-family:'DM Serif Display',serif;font-size:1.25rem;color:var(--gold);margin:0 0 .75rem;">Integration + Endurance</p>
      <p style="font-size:.8rem;color:var(--muted);line-height:1.65;margin:0;">
        Returning to senior leadership after a big transition — two kids under three, a new role, a lot of building.
        Focus: sustainable systems, deep presence, and living the questions across work, family, and self.
      </p>
    </div>
    <div style="background:var(--surface);padding:2rem;">
      <p style="font-size:.6rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin:0 0 .75rem;">Bucket List (Excerpt)</p>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.4rem;">
        {[
          'Antarctica + aurora borealis',
          'Camino de Santiago',
          'Stand-up comedy set (actually good)',
          'Knife from scratch, woodworking',
          'Burning Man',
          'Scuba — Great Barrier Reef',
          'Hut-to-hut hike with the kids',
        ].map(b => (
          <li style="font-size:.775rem;color:var(--muted);display:flex;gap:.5rem;">
            <span style="color:var(--border-hi);flex-shrink:0;">○</span>{b}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Contact -->
  <section style="border-top:1px solid var(--border);padding-top:2.5rem;margin-bottom:2rem;">
    <h2 style="font-size:.7rem;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin-bottom:1.5rem;">Get in Touch</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,240px),1fr));gap:1px;border:1px solid var(--border);background:var(--border);">
      {[
        { label: 'LinkedIn', value: 'linkedin.com/in/dimaperkis', href: 'https://linkedin.com/in/dimaperkis' },
        { label: 'Email', value: 'dperkis@lahzo.com', href: 'mailto:dperkis@lahzo.com' },
        { label: 'Best for', value: 'AI strategy, analytics leadership, building something interesting together', href: null },
      ].map(c => (
        <div style="background:var(--surface);padding:1.25rem 1.5rem;">
          <p style="font-size:.6rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin:0 0 .4rem;">{c.label}</p>
          {c.href ? (
            <a href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined}
              style="font-size:.8rem;color:var(--gold);text-decoration:none;transition:opacity .15s;" onmouseover="this.style.opacity='.7'" onmouseout="this.style.opacity='1'">
              {c.value} ↗
            </a>
          ) : (
            <p style="font-size:.8rem;color:var(--ink);margin:0;line-height:1.5;">{c.value}</p>
          )}
        </div>
      ))}
    </div>
  </section>

</Layout>
