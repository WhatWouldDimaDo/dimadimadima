---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const songs = (await getCollection('posts'))
  .filter(p => !p.data.draft && p.data.type === 'song' && p.data.youtube)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const song = songs[0];

function ytId(url: string) {
  const match = url?.match(/(?:youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/watch\?v=)([^&?/\s]+)/);
  return match ? match[1] : null;
}

const songVideoId = song?.data.youtube ? ytId(song.data.youtube) : null;
const songThumbnail = songVideoId ? `https://img.youtube.com/vi/${songVideoId}/hqdefault.jpg` : null;
---

<Layout
  title="Dima Perkis"
  description="Data & AI leader who turns emerging technology into measurable value—from enterprise strategy to production systems."
  defaultTheme="light"
>
  <main class="home-shell">
    <section class="masthead" aria-labelledby="home-title">
      <div class="identity-lockup" aria-label="Dima Perkis">
        <img
          class="identity-mark"
          src="/images/brand/dima-dima-dima/dima-mark-concept-01-transparent.png"
          alt=""
          aria-hidden="true"
        />
        <div class="identity-words">
          <h1 id="home-title" class="identity-first">Dima</h1>
          <div class="identity-last">Perkis</div>
        </div>
      </div>

      <div class="masthead-copy">
        <p>
          Data &amp; AI leader who turns emerging technology into measurable value—from
          enterprise strategy to production systems.
        </p>
      </div>

      <div class="proof-grid" aria-label="Selected facts">
        <div><strong>$140M+</strong><span>Delivered value</span></div>
        <div><strong>15+</strong><span>Years of experience</span></div>
        <div><strong>23</strong><span>AI projects live</span></div>
        <div><strong>2</strong><span>Toddlers</span></div>
      </div>
    </section>

    <section class="work-heading" aria-labelledby="selected-work-title">
      <div>
        <p class="section-label">Selected projects</p>
        <h2 id="selected-work-title">Projects you can open</h2>
      </div>
      <a href="/projects">All projects <span aria-hidden="true">→</span></a>
    </section>

    <section class="portfolio-grid" aria-label="Featured projects">
      <article class="project-card project-card--feature card-dewey">
        <div class="card-media card-media--dewey">
          <img src="/images/dewey/dewey-check-list.png" alt="Dewey checking a reading list against the library catalog" />
        </div>
        <div class="card-copy">
          <span class="card-kicker">Featured build</span>
          <div class="card-title-row"><h2>Dewey</h2></div>
          <p>Family book recommendations, checked live against Fulton County Library inventory.</p>
          <div class="card-actions">
            <a class="card-action-primary" href="https://dimadimadima.com/dewey" target="_blank" rel="noopener noreferrer">Open Dewey ↗</a>
            <a href="/projects/dewey">Project notes →</a>
          </div>
        </div>
      </article>

      <article class="radar-card">
        <div class="radar-brand">
          <span class="radar-icon"><img src="/atl/favicon.svg" alt="" /></span>
          <span>On Dima’s Radar</span>
        </div>
        <div class="radar-title-row">
          <h2>Happening in Atlanta</h2>
        </div>
        <div id="atl-live-list" class="radar-list">
          <div class="radar-empty">Loading the radar…</div>
        </div>
        <p class="radar-foot">Atlanta events worth leaving the house for, ranked by my event-intelligence pipeline.</p>
        <div class="card-actions radar-actions">
          <a class="card-action-primary" href="https://dimadimadima.com/atl" target="_blank" rel="noopener noreferrer">Open Radar ↗</a>
          <a href="/projects/atl-radar">Project notes →</a>
        </div>
      </article>

      <article class="project-card card-ideas">
        <div class="card-media"><img src="/images/ai-ideas-galaxy.png" alt="AI Ideas Explorer idea galaxy" /></div>
        <div class="card-copy">
          <span class="card-kicker">AI research</span>
          <div class="card-title-row"><h2>AI Ideas Explorer</h2></div>
          <p>1,160 business ideas generated, scored, and mapped.</p>
          <div class="card-actions"><a class="card-action-primary" href="https://ai-ideas-explorer.vercel.app" target="_blank" rel="noopener noreferrer">Open app ↗</a><a href="/projects/ai-ideas-explorer">Details →</a></div>
        </div>
      </article>

      <article class="project-card card-toddlermaps">
        <div class="card-media"><img src="/images/toddlermaps/toddlermaps-overview-map.png" alt="ToddlerMaps printable neighborhood map" /></div>
        <div class="card-copy">
          <span class="card-kicker">Family tool</span>
          <div class="card-title-row"><h2>ToddlerMaps</h2></div>
          <p>Navigation translated into landmarks a toddler actually knows.</p>
          <div class="card-actions"><a class="card-action-primary" href="https://dimadimadima.com/toddlermaps" target="_blank" rel="noopener noreferrer">Open app ↗</a><a href="/projects/toddlermaps">Details →</a></div>
        </div>
      </article>

      <article class="project-card card-power">
        <div class="card-media"><img src="/images/power-dashboard.png" alt="Georgia Power energy-analysis dashboard" /></div>
        <div class="card-copy">
          <span class="card-kicker">Personal data</span>
          <div class="card-title-row"><h2>Georgia Power</h2></div>
          <p>13 months and 10,487 hourly readings turned into an energy playbook.</p>
          <div class="card-actions"><a class="card-action-primary" href="https://dimadimadima.com/power" target="_blank" rel="noopener noreferrer">Open dashboard ↗</a><a href="/projects/power-analysis">Details →</a></div>
        </div>
      </article>

      <article class="project-card card-suno">
        <div class="card-media card-media--suno">
          {songThumbnail && <img src={songThumbnail} alt={song?.data.title ?? 'Suno Factory'} />}
          <span class="play-button" aria-hidden="true">▶</span>
        </div>
        <div class="card-copy">
          <span class="card-kicker">Creative system</span>
          <div class="card-title-row"><h2>Suno Factory</h2></div>
          <p>An end-to-end pipeline for turning family stories into finished songs.</p>
          <div class="card-actions">
            <a class="card-action-primary" href={song?.data.youtube ?? '/projects/suno-factory'} target={song?.data.youtube ? '_blank' : undefined} rel={song?.data.youtube ? 'noopener noreferrer' : undefined}>{song?.data.youtube ? 'Play latest ↗' : 'Explore →'}</a>
            <a href="/projects/suno-factory">Details →</a>
          </div>
        </div>
      </article>

      <article class="project-card card-music">
        <div class="card-media"><img src="/images/spotify-hero.png" alt="Dima’s music listening analysis" /></div>
        <div class="card-copy">
          <span class="card-kicker">Personal data</span>
          <div class="card-title-row"><h2>Music Data</h2></div>
          <p>18 years, 147,594 streams, and 178 concerts—visualized.</p>
          <div class="card-actions"><a class="card-action-primary" href="https://dima-spotify.vercel.app" target="_blank" rel="noopener noreferrer">Open site ↗</a><a href="/projects/spotify-analysis">Details →</a></div>
        </div>
      </article>

      <article class="project-card card-killbill">
        <div class="card-media"><img src="/images/kill-bill.jpg" alt="All Roads to Kill Bill" /></div>
        <div class="card-copy">
          <span class="card-kicker">Film graph</span>
          <div class="card-title-row"><h2>All Roads to Kill Bill</h2></div>
          <p>Every Tarantino connection in one explorable graph.</p>
          <div class="card-actions"><a class="card-action-primary" href="https://allroadstokillbill.vercel.app" target="_blank" rel="noopener noreferrer">Open graph ↗</a><a href="/projects/kill-bill">Details →</a></div>
        </div>
      </article>
    </section>
  </main>

  <script is:inline>
    (function () {
      function renderRadar() {
        try {
          var list = document.getElementById('atl-live-list');
          if (!list || typeof EVENTS === 'undefined') return;
          var today = new Date();
          today.setHours(0, 0, 0, 0);
          var upcoming = EVENTS
            .filter(function (event) { return new Date(event.dateEnd || event.date) >= today; })
            .sort(function (a, b) { return (b.score || 0) - (a.score || 0); })
            .slice(0, 14)
            .sort(function (a, b) { return new Date(a.date) - new Date(b.date); })
            .slice(0, 3);
          if (!upcoming.length) return;
          list.innerHTML = upcoming.map(function (event) {
            var isAbsolute = event.imageUrl && /^https?:\/\//i.test(event.imageUrl);
            var imageSrc = event.imageUrl ? (isAbsolute ? event.imageUrl : '/atl/' + event.imageUrl) : null;
            var thumbnail = imageSrc
              ? '<img class="radar-thumb" src="' + imageSrc + '" alt="" loading="lazy" onerror="this.outerHTML=\'<span class=&quot;radar-thumb radar-thumb--emoji&quot;>' + (event.emoji || '📅') + '</span>\'">'
              : '<span class="radar-thumb radar-thumb--emoji">' + (event.emoji || '📅') + '</span>';
            return '<div class="radar-row">'
              + thumbnail
              + '<span class="radar-event"><span class="radar-name">' + event.title + '</span>'
              + '<span class="radar-venue">' + event.dateStr + ' · ' + (event.venue || '') + '</span></span>'
              + '</div>';
          }).join('');
        } catch (error) { /* keep the loading fallback */ }
      }

      function loadRadar() {
        var script = document.createElement('script');
        script.src = '/atl/data.js';
        script.onload = renderRadar;
        document.body.appendChild(script);
      }

      if ('requestIdleCallback' in window) requestIdleCallback(loadRadar);
      else setTimeout(loadRadar, 250);
    })();
  </script>
</Layout>

<style>
  .home-shell { padding: 2rem 0 5rem; }

  .masthead {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(18rem, .95fr);
    gap: clamp(2rem, 6vw, 5.5rem);
    align-items: center;
    padding: clamp(2rem, 5vw, 4rem);
    border: 1px solid var(--border);
    border-radius: 24px;
    background: color-mix(in srgb, var(--surface) 84%, transparent);
  }

  .identity-lockup {
    display: flex;
    align-items: stretch;
    gap: clamp(.9rem, 1.7vw, 1.25rem);
    width: max-content;
    max-width: 100%;
  }

  .identity-mark {
    width: clamp(8.75rem, 16vw, 10rem);
    height: auto;
    display: block;
    flex: 0 0 auto;
  }

  .identity-words {
    display: flex;
    min-width: 0;
    flex-direction: column;
    justify-content: space-between;
    padding: .05em 0 .08em;
  }
  .identity-first,
  .identity-last {
    margin: 0;
    color: var(--ink);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-weight: 650;
    letter-spacing: -.065em;
    font-size: clamp(3rem, 6vw, 4.1rem);
    line-height: .88;
  }
  .identity-last { margin: 0; }

  .masthead-copy { max-width: 30rem; }
  .masthead-copy p {
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    line-height: 1.7;
  }
  .proof-grid {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }
  .proof-grid > div {
    display: flex;
    flex-direction: column;
    gap: .35rem;
    padding: 0 1.4rem;
    border-right: 1px solid var(--border);
  }
  .proof-grid > div:first-child { padding-left: 0; }
  .proof-grid > div:last-child { border-right: 0; }
  .proof-grid strong { color: var(--ink); font-size: clamp(1.55rem, 3vw, 2rem); letter-spacing: -.055em; }
  .proof-grid span {
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: .65rem;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .work-heading {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    padding: 4rem 0 1.35rem;
  }
  .section-label,
  .card-kicker {
    margin: 0;
    color: var(--gold);
    font-family: 'DM Mono', monospace;
    font-size: .68rem;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .work-heading h2 { margin: .35rem 0 0; font-size: clamp(1.8rem, 4vw, 2.7rem); letter-spacing: -.045em; }
  .work-heading > a {
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: .72rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: .08em;
  }
  .work-heading > a:hover { color: var(--gold); }

  .portfolio-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 1rem; }

  .project-card,
  .radar-card {
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: var(--surface);
    color: inherit;
    text-decoration: none;
    transition: transform .24s ease, border-color .24s ease, box-shadow .24s ease;
  }
  .project-card:hover,
  .radar-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--gold) 42%, var(--border));
    box-shadow: 0 20px 44px -32px color-mix(in srgb, var(--ink) 45%, transparent);
  }

  .project-card { display: grid; grid-template-rows: auto 1fr; }
  .card-media { position: relative; overflow: hidden; aspect-ratio: 16 / 10; border-bottom: 1px solid var(--border); background: var(--bg); }
  .card-media img { display: block; width: 100%; height: 100%; object-fit: cover; object-position: top center; transition: transform .45s ease; }
  .project-card:hover .card-media img { transform: scale(1.025); }
  .card-media--dewey { aspect-ratio: 16 / 8.7; }
  .card-media--dewey img { object-position: top left; }
  .card-media--suno { aspect-ratio: 16 / 8; background: #090a0c; }
  .card-media--suno img { object-position: center; filter: brightness(.72); }

  .card-copy { display: flex; flex-direction: column; padding: 1.2rem 1.25rem 1.35rem; }
  .card-title-row,
  .radar-title-row { display: flex; justify-content: space-between; align-items: start; gap: 1rem; }
  .card-title-row h2,
  .radar-title-row h2 { margin: .55rem 0 .4rem; color: var(--ink); font-size: 1.25rem; letter-spacing: -.035em; line-height: 1.12; }
  .card-title-row > span,
  .radar-title-row > span { color: var(--gold); font-size: 1.15rem; transform: translateY(.45rem); }
  .card-copy p { margin: 0; color: var(--muted); font-size: .84rem; line-height: 1.55; }
  .project-card--feature .card-title-row h2 { font-size: 1.55rem; }
  .project-card--feature .card-copy p { max-width: 42rem; font-size: .92rem; }

  .card-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: .55rem 1rem;
    margin-top: auto;
    padding-top: 1.1rem;
  }
  .card-actions a {
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: .64rem;
    font-weight: 600;
    letter-spacing: .05em;
    text-decoration: none;
    text-transform: uppercase;
  }
  .card-actions a:hover { color: var(--ink); }
  .card-actions .card-action-primary {
    padding: .55rem .72rem;
    border: 1px solid color-mix(in srgb, var(--gold) 55%, var(--border));
    border-radius: 7px;
    background: color-mix(in srgb, var(--gold) 9%, transparent);
    color: var(--ink);
  }

  .card-dewey { grid-column: span 7; }
  .radar-card { grid-column: span 5; }
  .card-ideas,
  .card-toddlermaps,
  .card-power { grid-column: span 4; }
  .card-suno { grid-column: span 6; }
  .card-music,
  .card-killbill { grid-column: span 3; }
  .card-toddlermaps .card-media img { object-position: center; }
  .card-killbill .card-media img { object-position: center 28%; }

  .play-button {
    position: absolute;
    inset: 50% auto auto 50%;
    display: grid;
    place-items: center;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    background: rgba(212, 168, 83, .94);
    color: #111;
    transform: translate(-50%, -50%);
  }

  .radar-card { display: flex; flex-direction: column; padding: 1.35rem 1.45rem; }
  .radar-brand { display: flex; align-items: center; gap: .65rem; color: #C45420; font-family: 'DM Mono', monospace; font-size: .7rem; letter-spacing: .14em; text-transform: uppercase; }
  .radar-icon { position: relative; display: inline-flex; width: 28px; height: 28px; flex: 0 0 auto; }
  .radar-icon img { width: 100%; height: 100%; }
  .radar-title-row h2 { margin-top: .85rem; font-size: 1.55rem; }
  .radar-list { display: flex; flex: 1; flex-direction: column; justify-content: center; margin-top: .3rem; }
  .radar-empty { color: var(--muted); font-family: 'DM Mono', monospace; font-size: .72rem; }
  .radar-card :global(.radar-row) { display: flex; align-items: center; gap: .8rem; padding: .62rem 0; border-bottom: 1px solid var(--border); }
  .radar-card :global(.radar-row:last-child) { border-bottom: 0; }
  .radar-card :global(.radar-thumb) { display: grid; place-items: center; width: 44px; height: 44px; flex: 0 0 auto; border: 1px solid var(--border); border-radius: 7px; object-fit: cover; background: var(--bg); }
  .radar-card :global(.radar-thumb--emoji) { font-size: 1.25rem; }
  .radar-card :global(.radar-event) { display: flex; min-width: 0; flex-direction: column; gap: .12rem; }
  .radar-card :global(.radar-name) { overflow: hidden; color: var(--ink); font-size: .86rem; text-overflow: ellipsis; white-space: nowrap; }
  .radar-card :global(.radar-venue) { overflow: hidden; color: var(--muted); font-family: 'DM Mono', monospace; font-size: .64rem; letter-spacing: .03em; text-overflow: ellipsis; text-transform: uppercase; white-space: nowrap; }
  .radar-foot { margin: .65rem 0 0; color: var(--muted); font-size: .78rem; line-height: 1.5; }
  .radar-actions { margin-top: .35rem; }

  @media (max-width: 860px) {
    .masthead { grid-template-columns: 1fr; gap: 1.75rem; }
    .masthead-copy { max-width: 42rem; }
    .proof-grid { grid-template-columns: repeat(2, 1fr); }
    .proof-grid > div { padding: 1rem; border-bottom: 1px solid var(--border); }
    .proof-grid > div:nth-child(2) { border-right: 0; }
    .proof-grid > div:nth-child(3) { padding-left: 0; border-bottom: 0; }
    .proof-grid > div:last-child { border-bottom: 0; }
    .card-dewey,
    .radar-card,
    .card-ideas,
    .card-toddlermaps,
    .card-power,
    .card-suno,
    .card-music,
    .card-killbill { grid-column: span 12; }
    .card-dewey { order: 1; }
    .radar-card { order: 2; }
    .card-ideas { order: 3; }
    .card-toddlermaps { order: 4; }
    .card-power { order: 5; }
    .card-suno { order: 6; }
    .card-music { order: 7; }
    .card-killbill { order: 8; }
  }

  @media (max-width: 560px) {
    .home-shell { padding: 1rem 0 3.5rem; }
    .masthead { gap: 1.35rem; padding: 1.25rem; border-radius: 18px; }
    .identity-mark { width: 6rem; }
    .identity-first,
    .identity-last { font-size: 2.25rem; }
    .masthead-copy p { font-size: 1rem; line-height: 1.58; }
    .proof-grid { padding-top: .35rem; }
    .proof-grid > div,
    .proof-grid > div:first-child,
    .proof-grid > div:nth-child(3) { padding: .85rem .65rem; }
    .proof-grid strong { font-size: 1.55rem; }
    .proof-grid span { font-size: .57rem; line-height: 1.35; }
    .work-heading { padding: 2.75rem 0 1rem; align-items: center; }
    .work-heading h2 { font-size: 1.85rem; }
    .work-heading > a { font-size: .62rem; }
    .portfolio-grid { gap: .75rem; }
    .project-card,
    .radar-card { border-radius: 15px; }
    .card-media,
    .card-media--dewey,
    .card-media--suno { aspect-ratio: 16 / 9; }
    .card-copy { padding: 1rem 1rem 1.1rem; }
    .card-title-row h2,
    .project-card--feature .card-title-row h2 { font-size: 1.15rem; }
    .card-copy p,
    .project-card--feature .card-copy p { font-size: .8rem; }
    .radar-card { padding: 1.1rem; }
    .radar-title-row h2 { font-size: 1.3rem; }
    .radar-card :global(.radar-name),
    .radar-card :global(.radar-venue) { white-space: normal; }
    .radar-foot { font-size: .74rem; }
  }
</style>
